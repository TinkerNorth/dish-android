<?xml version="1.0" encoding="utf-8"?>
<!--
    STATE-LIST SUPPORT TOKENS — the values referenced by state-list color
    selectors living in `res/color/`. Android's resource system mandates
    that `<selector>` resources sit in `res/color/`, so the selectors
    themselves are individual files there; this values file is the index
    + the home for any state-list-only semantic aliases that don't
    naturally belong in `colors.xml` or `colors_primitives.xml`.

    Selectors in res/color/:
      - chip_pickable_text.xml — flips on state_selected (chip label).
      - text_disabled.xml      — fades on state_enabled=false (text).
      - icon_interactive.xml   — primary→muted on state_enabled=false.
      - icon_secondary.xml     — always muted, kept selector-shaped for
                                 callsite consistency.

    When adding a new state-list color: create the selector in res/color/,
    add a one-line entry in the list above. Add a semantic alias here only
    if the same value is reused across multiple selectors.
-->
<resources>
    <!-- Disabled-text fade. Aliased so callsites referencing this state-
         list value (e.g. a future "subdued caption" surface) point at the
         same token text_disabled.xml's disabled branch uses. -->
    <color name="colorTextDisabled">@color/paper_50_a40</color>
</resources>
