<resources>
    <string name="app_name">Dish</string>

    <!-- MainActivity dashboard. Vocabulary aligns with LinkState chips:
         a remembered/paired entry is "paired"; a Connected entry is "online". -->
    <string name="status_remembered">%1$d paired</string>
    <string name="status_tap_manage">Tap Manage to add one</string>
    <string name="status_connected_of">%1$d of %2$d online</string>
    <string name="toast_pairing_needed">Pairing needed — open Connections</string>
    <string name="toast_bind_first">Bind a connection first</string>

    <!-- Touch-overlay phone-motion (gyro/accel) indicator. States: streaming,
         paused (overlay backgrounded), not-forwarded (Bluetooth connection
         has no motion channel), and not-available (no gyroscope). -->
    <string name="motion_streaming">Motion: streaming</string>
    <string name="motion_paused">Motion: paused</string>
    <string name="motion_not_forwarded">Motion: not sent</string>
    <string name="motion_unavailable">Motion: no gyroscope</string>
    <!-- Detail lines, shown only for the two states that need an explanation
         so the user understands the limit rather than seeing a bare label. -->
    <string name="motion_unavailable_detail">This phone has no gyroscope, so motion (gyro aim / tilt) is not sent.</string>
    <string name="motion_not_forwarded_detail">This Bluetooth connection has no motion channel. Use a satellite connection to send gyro aim / tilt.</string>

    <!-- Per-slot battery indicator on the controller list (Task 1.2). -->
    <!-- Battery percentage, e.g. "84%". -->
    <string name="battery_percent">%1$d%%</string>
    <!-- Shown when the controller reports a charging state but no percentage. -->
    <string name="battery_unknown_level">--</string>

    <!-- Dynamic battery contentDescription for screen readers — built from the
         actual level + charging state so the icon is not announced as a static
         "battery level" with no value. %1$s is a localised level (a percentage
         or "unknown"); %2$s is a localised charging-state phrase below. -->
    <string name="battery_desc">Controller battery %1$s, %2$s</string>
    <string name="battery_desc_level_unknown">level unknown</string>
    <string name="battery_state_charging">charging</string>
    <string name="battery_state_low">low, not charging</string>
    <string name="battery_state_discharging">on battery</string>

    <!-- Connections list: how a discovered satellite was found. Shown in the
         row subtitle after "Found · ". -->
    <string name="discovery_source_broadcast">UDP broadcast</string>
    <string name="discovery_source_mdns">mDNS</string>
    <string name="discovery_source_both">mDNS + broadcast</string>
</resources>
