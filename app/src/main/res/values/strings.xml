<resources>
    <string name="app_name">Dish</string>
    <!-- Brand wordmark — dashboard header and the native-load fallback screen.
         Treated as a non-translatable brand asset. -->
    <string name="brand_name" translatable="false">DISH</string>

    <!-- MainActivity dashboard. Vocabulary aligns with LinkState chips:
         a remembered/paired entry is "paired"; a Connected entry is "online". -->
    <plurals name="status_remembered">
        <item quantity="one">%1$d paired</item>
        <item quantity="other">%1$d paired</item>
    </plurals>
    <string name="status_tap_manage">Tap Manage to add one</string>
    <!-- Quantity is selected on the *total* count (the "of N" number): "1 of 1
         online" reads singular, "2 of 5 online" reads plural. Pass total as the
         quantity arg first, then both `online` and `total` as positional args. -->
    <plurals name="status_connected_of">
        <item quantity="one">%1$d of %2$d online</item>
        <item quantity="other">%1$d of %2$d online</item>
    </plurals>
