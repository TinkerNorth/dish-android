<resources>
    <string name="app_name">Dish</string>

    <!-- MainActivity dashboard. Vocabulary aligns with LinkState chips:
         a remembered/paired entry is "paired"; a Connected entry is "online". -->
    <string name="status_remembered">%1$d paired</string>
    <string name="status_tap_manage">Tap Manage to add one</string>
    <string name="status_connected_of">%1$d of %2$d online</string>
    <string name="toast_pairing_needed">Pairing needed — open Connections</string>
    <string name="toast_bind_first">Bind a connection first</string>

    <!-- Touch-overlay phone-motion (gyro/accel) indicator. States: streaming,
         paused (overlay backgrounded), not-forwarded (Bluetooth connection
         has no motion channel), and not-available (no gyroscope). -->
    <string name="motion_streaming">Motion: streaming</string>
    <string name="motion_paused">Motion: paused</string>
    <string name="motion_stalled">Motion: stalled</string>
    <string name="motion_not_forwarded">Motion: not sent</string>
    <string name="motion_unavailable">Motion: no gyroscope</string>
    <!-- Detail lines, shown only for the states that need an explanation
         so the user understands the limit rather than seeing a bare label. -->
    <string name="motion_unavailable_detail">This phone has no gyroscope, so motion (gyro aim / tilt) is not sent.</string>
    <string name="motion_not_forwarded_detail">This Bluetooth connection has no motion channel. Use a satellite connection to send gyro aim / tilt.</string>
    <string name="motion_stalled_detail">Motion sensor stalled — try toggling the back button to reset, or restart Dish.</string>

    <!-- Per-slot battery indicator on the controller list (Task 1.2). -->
    <!-- Battery percentage, e.g. "84%". -->
    <string name="battery_percent">%1$d%%</string>
    <!-- Shown when the controller reports a charging state but no percentage. -->
    <string name="battery_unknown_level">--</string>

    <!-- Dynamic battery contentDescription for screen readers — built from the
         actual level + charging state so the icon is not announced as a static
         "battery level" with no value. %1$s is a localised level (a percentage
         or "unknown"); %2$s is a localised charging-state phrase below. -->
    <string name="battery_desc">Controller battery %1$s, %2$s</string>
    <string name="battery_desc_level_unknown">level unknown</string>
    <string name="battery_state_charging">charging</string>
    <string name="battery_state_low">low, not charging</string>
    <string name="battery_state_discharging">on battery</string>

    <!-- Connections list: how a discovered satellite was found. Shown in the
         row subtitle after "Found · ". -->
    <string name="discovery_source_broadcast">UDP broadcast</string>
    <string name="discovery_source_mdns">mDNS</string>
    <string name="discovery_source_both">mDNS + broadcast</string>

    <!-- DishNotification action labels. Short, imperative, allCaps + tracked
         to match the v6 Outlined Button label conventions. -->
    <string name="action_open_settings">SETTINGS</string>
    <string name="action_retry">RETRY</string>
    <string name="action_reconnect">RECONNECT</string>
    <string name="action_repair">RE-PAIR</string>
    <string name="action_open">OPEN</string>
    <string name="action_forget">FORGET</string>
    <string name="action_turn_on">TURN ON</string>
    <string name="action_grant">GRANT</string>

    <!-- DishNotification copy. Hoisted to strings.xml so the wording can be
         tuned in one place (and localised later) rather than being scattered
         across data + UI sites. -->
    <string name="notif_bt_permission_title">Bluetooth permission needed</string>
    <string name="notif_bt_permission_body">Dish needs Bluetooth access to register a controller.</string>
    <string name="notif_bt_discoverability_denied_title">Discoverability denied</string>
    <string name="notif_bt_discoverability_denied_body">Your host can\'t see this phone until you make it discoverable.</string>
    <string name="notif_bt_adapter_off_title">Bluetooth is off</string>
    <string name="notif_bt_adapter_off_body">Turn on Bluetooth to use a controller host.</string>
    <string name="notif_bt_unsupported_title">Bluetooth HID requires Android 9+</string>
    <string name="notif_bt_unsupported_body">This device can\'t pair as a Bluetooth controller.</string>
    <string name="notif_bt_key_missing_title">Re-pair %1$s</string>
    <string name="notif_bt_key_missing_body">The host forgot its end of the pairing. Forget on both sides + re-pair.</string>
    <string name="notif_bt_bond_removed_title">%1$s unpaired</string>
    <string name="notif_bt_bond_removed_body">Re-pair to reconnect.</string>
    <string name="notif_no_network_title">No network</string>
    <string name="notif_no_network_body">Connect to the same Wi-Fi as your satellite.</string>
    <string name="notif_cellular_only_title">Mobile data only</string>
    <string name="notif_cellular_only_body">Satellites live on your Wi-Fi LAN, not on mobile data.</string>
    <string name="notif_bind_first_title">Bind a connection first</string>
    <string name="notif_pairing_needed_title">Pairing needed</string>
    <string name="notif_pairing_needed_body">Open Connections to enter the PIN for %1$s.</string>
    <string name="notif_server_unreachable_title">%1$s isn\'t responding</string>
    <string name="notif_server_unreachable_body">Check it\'s powered on and on the same Wi-Fi.</string>
    <string name="notif_registration_failed_title">Controller registration failed</string>
    <string name="notif_pair_pin_failed_title">PIN didn\'t match</string>
    <string name="notif_session_lost_title">Connection to %1$s lost</string>
    <string name="notif_session_lost_body">Reconnecting…</string>

    <!-- Dynamic empty state for the satellites list. -->
    <string name="discovery_empty_never_scanned">Tap Scan to find satellites on your network</string>
    <string name="discovery_empty_no_results">No satellites found at %1$s — check Wi-Fi and that your host is powered.</string>

    <!-- Custom PIN dialog. -->
    <string name="pair_dialog_title">Pair with satellite</string>
    <string name="pair_dialog_subtitle">Enter the PIN shown on your satellite.</string>
    <string name="pair_dialog_pin_hint">PIN</string>
    <string name="pair_dialog_submit">PAIR</string>
    <string name="pair_dialog_cancel">CANCEL</string>
    <string name="pair_dialog_pairing">PAIRING…</string>
    <string name="pair_dialog_error_empty">Enter the PIN shown on your satellite.</string>

    <!-- Foreground service notification. -->
    <string name="streaming_channel_name">Streaming session</string>
    <string name="streaming_channel_description">Keeps Dish running while a controller is streaming.</string>
    <string name="streaming_notification_title">Dish · Streaming</string>
    <string name="streaming_notification_body">%1$d controller streaming to %2$s</string>
    <string name="streaming_notification_body_plural">%1$d controllers streaming</string>
    <string name="streaming_notification_stop">Stop</string>

    <!-- Native-load fatal fallback. -->
    <string name="fatal_native_title">This build won\'t run on your device</string>
    <string name="fatal_native_body">The Dish native library couldn\'t load. Please reinstall from the Play Store, or contact support.</string>
</resources>
