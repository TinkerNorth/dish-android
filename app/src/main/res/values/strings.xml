    <!-- Labels for the two side-by-side trackpads in the touchpad overlay.
         The "click" pad routes touches as click+position (drag, text
         select); the "move" pad sends position only. Mutually exclusive
         under the hood — once one pad has an active finger the other is
         locked out until release. -->
    <string name="touchpad_pad_click_label">Click + Move</string>
    <string name="touchpad_pad_move_label">Move</string>
    <!-- Subtitle under each pad's label hinting at what it does. Two lines
         of caption type, short enough not to crowd the surface. -->
    <string name="touchpad_pad_click_hint">Drag to click and move</string>
    <string name="touchpad_pad_move_hint">Drag to move cursor</string>

