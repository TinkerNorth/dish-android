<?xml version="1.0" encoding="utf-8"?>
<!--
    WIDGET STYLES — component-level closure for repeated Material widget
    configurations. Every MaterialCardView, MaterialToolbar, status dot,
    section/card icon, switch, and PIN field in the project adopts one
    of these via `style="@style/Widget.Dish.X"`.

    Two Button styles (`Widget.Dish.Button`, `Widget.Dish.Button.Outlined`)
    are kept in `themes.xml` next to `Theme.Dish` because the theme wires
    `materialButtonStyle = Widget.Dish.Button` as the global default.

    Naming convention:
      Widget.Dish.<Component>[.<Variant>]
        Component = Card / Toolbar / StatusDot / EmptyStateText / Switch /
                    EditText / Icon
        Variant   = Large / Section / Card / Pin / Overlay

    Visual no-op invariant: each callsite migrating to a Widget.Dish.* style
    is byte-identical in rendering. Inline attribute removal is mechanical;
    if a callsite still needs a different value, override that specific
    attribute inline and document why.
-->
<resources>

    <!-- ============================================================
         CARDS
         All MaterialCardView callsites share five attributes.

         Variant choice — DELIBERATE M3 DEVIATION:
           M3 spec recommends `Widget.Material3.CardView.Filled` with
           `colorSurfaceContainerLow` for *ungrouped data cards* (the
           slot cards on the dashboard, the Settings cards) and reserves
           `Widget.Material3.CardView.Outlined` for *groups of cards on a
           single surface* that need a lighter-weight separator.

           Dish picks Outlined for everything because the brand language
           is "deep-space flat" — every card stays at elevation 0, the
           elevation overlay is disabled theme-wide (see Theme.Dish), and
           the load-bearing visual signal is the 12%-alpha cyan stroke
           (colorCardStroke). Switching to Filled would introduce a
           tonal surface lift that conflicts with the brand intent.

           Re-evaluate if a future surface needs to read as "elevated"
           against the background — at that point M3 Filled +
           colorSurfaceContainerLow is the right tool, and the surface
           container hierarchy is now pinned in Theme.Dish for it.
         ============================================================ -->
    <style name="Widget.Dish.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardCornerRadius">@dimen/corner_card</item>
        <item name="cardElevation">@dimen/elevation_none</item>
        <item name="strokeColor">@color/colorCardStroke</item>
        <item name="strokeWidth">@dimen/border_thin</item>
    </style>

    <!-- Inner LinearLayout wrapper for a Settings-style card row: the
         horizontal slot that hosts a `card_row_icon_label_value` include
         alongside a trailing affordance (MaterialSwitch, chevron ImageView,
         etc.) inside a Widget.Dish.Card. Captures the orientation +
         card_padding the two Settings card wrappers (Crash, Privacy) share.

         Gravity is left to the callsite: `top` for multi-line rows whose
         subtitle wraps and whose trailing affordance should align to the
         title baseline (Crash); `center_vertical` for single-line rows
         where the trailing chevron sits beside the centred text (Privacy).

         Not adopted by the Settings version row — its padding is asymmetric
         (`card_padding_horizontal` + `size_11` vertical) because the row is
         a single-line label/value pair, not an icon-plus-text composite. -->
    <style name="Widget.Dish.Card.RowContainer" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">@dimen/card_padding</item>
    </style>

    <!-- ============================================================
         TOOLBAR
         The two Activity toolbars (Connections, Settings) only differ
         in `app:title`. Background, title colour, and navigation icon
         collapse into the style.
         ============================================================ -->
    <style name="Widget.Dish.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/colorBackground</item>
        <item name="titleTextColor">@color/colorOnSurface</item>
        <item name="navigationIcon">@drawable/ic_chevron_left</item>
        <item name="android:layout_height">?attr/actionBarSize</item>
    </style>

    <!-- ============================================================
         STATUS DOT — bare View with the dot_circle drawable, sized to
         the icon_dot_lg semantic dimen. The drawable's fill is set
         programmatically (live/connecting/idle/error) by the hosting
         Activity/Adapter; the style owns geometry + background.
         ============================================================ -->
    <style name="Widget.Dish.StatusDot.Large" parent="">
        <item name="android:layout_width">@dimen/icon_dot_lg</item>
        <item name="android:layout_height">@dimen/icon_dot_lg</item>
        <item name="android:background">@drawable/dot_circle</item>
    </style>

    <!-- ============================================================
         EMPTY STATE TEXT — three-style ramp: base (geometry + text
         appearance) plus two context variants. The base is never used
         on its own; callsites pick either Picker or Section so the
         empty-state row carries the right breathing room for its
         surroundings.
           - Picker: nested inside a slot card body — small top margin
             so it sits just under the prior picker row.
           - Section: standalone empty-state row inside a section (no
             surrounding card) — vertical padding so the section
             divider above/below doesn't crowd it.
         ============================================================ -->
    <style name="Widget.Dish.EmptyStateText" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.Dish.BodySmall</item>
    </style>

    <!-- Used by `picker_empty_label.xml`, inflated by ControllerAdapter
         when the slot picker has no connections to show. -->
    <style name="Widget.Dish.EmptyStateText.Picker">
        <item name="android:layout_marginTop">@dimen/spacing_xs</item>
    </style>

    <!-- Used by `activity_connections.xml`'s tvSatelliteEmpty + tvBtEmpty.
         Vertical padding (instead of margin) keeps the empty-state row's
         click area the full height so the inter-section divider above/
         below visually separates it from the section header / next
         section, not from the text bounds.
         paddingTop + paddingBottom (not paddingVertical) because
         android:paddingVertical is API 26+ and style items can't carry
         a tools:targetApi annotation — same rule that pinned autofill
         attributes inline on `Widget.Dish.EditText.Pin`. -->
    <style name="Widget.Dish.EmptyStateText.Section">
        <item name="android:paddingTop">@dimen/spacing_xl</item>
        <item name="android:paddingBottom">@dimen/spacing_xl</item>
    </style>

    <!-- ============================================================
         SWITCH — Material 3 MaterialSwitch with the empty-label /
         no-side-text configuration the design uses everywhere a
         switch shows up. Thumb + track colors are picked up from
         the Material theme's colorPrimary / colorOnSurface so no
         explicit thumbTint / trackTint here.
         Callsites use `com.google.android.material.materialswitch.MaterialSwitch`
         (the M3 switch widget) — different class from the older
         `SwitchMaterial` (M2) the codebase used pre-migration.
         ============================================================ -->
    <style name="Widget.Dish.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="android:textOn"></item>
        <item name="android:textOff"></item>
        <item name="showText">false</item>
    </style>

    <!-- ============================================================
         TEXT INPUT — pair-dialog PIN field. M3 TextInputLayout (Outlined
         box variant) wrapping a TextInputEditText. The brand intent is a
         field that "looks interactive even when not focused" — Material's
         default OutlinedBox renders a faint stroke when unfocused that
         doesn't match. Widget.Dish.TextInputLayout.Pin pins
         `boxStrokeColor` to colorPrimary at full saturation in BOTH
         resting and focused states, and keeps the stroke width constant
         across states so the box doesn't visually "click in" on focus.

         Error state: TextInputLayout.setError(msg) flips the stroke +
         the helper-text below into colorError. The dialog used to host
         a separate `tvPairError` TextView under the field for this; the
         text-input-layout migration replaces that pattern with the
         M3-native error affordance, which also announces the error
         via a11y live-region semantics (the prior TextView did not).

         Hint is disabled on the layout — the dialog renders its own
         title above the field, so the floating-label affordance would
         duplicate it. Counter is disabled — the PIN is a 4–8 digit
         numeric secret; a visible "x / 8" counter would just leak the
         max-length to the user.
         ============================================================ -->
    <style name="Widget.Dish.TextInputLayout.Pin" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="boxStrokeWidth">@dimen/border_thin</item>
        <item name="boxStrokeWidthFocused">@dimen/border_thin</item>
        <item name="boxStrokeErrorColor">@color/colorError</item>
        <item name="boxBackgroundColor">@color/colorBackground</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_picker_row</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_picker_row</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_picker_row</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_picker_row</item>
        <item name="hintEnabled">false</item>
        <item name="counterEnabled">false</item>
        <item name="errorEnabled">true</item>
        <item name="errorIconDrawable">@null</item>
        <item name="errorTextColor">@color/colorError</item>
    </style>

    <!-- The TextInputEditText nested inside Widget.Dish.TextInputLayout.Pin.
         autofillHints + importantForAutofill stay inline at the callsite
         (API 26+; style items can't carry a tools:targetApi annotation).
         No background drawable here — TextInputLayout draws the outlined
         box around the EditText. -->
    <style name="Widget.Dish.EditText.Pin" parent="Widget.Material3.TextInputEditText.OutlinedBox">
        <item name="android:inputType">number</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_display</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textColorHint">@color/colorMuted</item>
        <item name="android:letterSpacing">0.30</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- ============================================================
         CHIP — the pickable chip used by the controller card's inline
         pickers (Type: Xbox/PS, Touchpad mode: Off/Pad/Mouse). MaterialChip
         in FilterChip mode (checkable=true, single-choice driven by the
         adapter rebinding `isChecked` from the new state). Adopted as the
         global default via `chipStyle` on Theme.Dish.

         Visual: filled when checked (colorPrimary background, navy text);
         flat with a subtle cyan stroke when unchecked (colorBackground
         background, paper text). State layer (hover / focus / press) is
         spec-correct M3 — driven by colorPrimary at the M3 ripple opacities.

         Checked-icon + chip-icon + close-icon all suppressed: this chip is
         a binary toggle indicator; the colour fill alone signals the
         "selected" state and there's no leading glyph or close affordance
         in the picker. textStart/EndPadding zeroed for the same reason
         (the default values reserve space for the leading checked-icon
         we don't show).

         Shape inherits the M3 shapeAppearanceCornerExtraSmall slot via the
         parent style — see Theme.Dish for the wiring. Min height is
         tightened from M3's default 32dp to 24dp to match the prior
         hand-rolled drawable chip's footprint inside the controller card
         picker row.

         a11y trade-off — DELIBERATE WCAG DEVIATION:
           ensureMinTouchTargetSize=false flips off M3's automatic 48dp
           tap-target inflation. The chip renders at its 24dp visual size
           with a 24dp effective tap target, below WCAG 2.5.5 Level AAA's
           44x44 minimum. This matches the prior hand-rolled chip's
           density (it had no min touch target either) so this isn't a
           regression — but it's now documented because the M3 chip flag
           makes the trade-off explicit instead of implicit. Re-evaluate
           by flipping the flag to true (gives 24dp visual + 48dp tap
           area) if the picker becomes thumb-driven enough to warrant
           the vertical-space cost.
         ============================================================ -->
    <style name="Widget.Dish.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="android:textAppearance">@style/TextAppearance.Dish.BodySmall</item>
        <item name="android:textColor">@color/chip_dish_text</item>
        <item name="chipBackgroundColor">@color/chip_dish_background</item>
        <item name="chipStrokeColor">@color/colorOutline</item>
        <item name="chipStrokeWidth">@dimen/border_thin</item>
        <item name="rippleColor">@color/colorPrimary</item>
        <item name="chipMinHeight">@dimen/chip_min_height</item>
        <item name="chipStartPadding">@dimen/chip_padding_horizontal</item>
        <item name="chipEndPadding">@dimen/chip_padding_horizontal</item>
        <item name="textStartPadding">0dp</item>
        <item name="textEndPadding">0dp</item>
        <item name="chipIconVisible">false</item>
        <item name="closeIconVisible">false</item>
        <item name="checkedIconVisible">false</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

    <!-- ============================================================
         ICONS — geometry-only styles for the section-header icons
         and leading card glyphs.
           - Icon.Section stays untinted so multi-tone artwork
             (ic_satellite, ic_bluetooth) keeps its embedded palette.
           - Icon.Card applies tint=colorPrimary; both current
             leading card glyphs (ic_bug, ic_shield) render cyan,
             matching the design.
         The trailing chevron on the privacy-policy card
         (ic_open_in_new) is intentionally muted and so does NOT
         adopt Icon.Card — it stays inline with no tint.
         ============================================================ -->
    <style name="Widget.Dish.Icon.Section" parent="">
        <item name="android:layout_width">@dimen/icon_section_header</item>
        <item name="android:layout_height">@dimen/icon_section_header</item>
    </style>

    <style name="Widget.Dish.Icon.Card" parent="">
        <item name="android:layout_width">@dimen/icon_card_glyph</item>
        <item name="android:layout_height">@dimen/icon_card_glyph</item>
        <item name="tint">@color/colorPrimary</item>
    </style>

    <!-- Widget.Dish.Button.Outlined.Overlay (and its supporting
         `touch_target_min` / `button_min_width` / `size_64` /
         `overlay_action_back` resources) was retired when the overlay
         activities adopted the shared `overlay_header.xml` composite —
         the back affordance is now the toolbar chevron, not an
         explicit BACK button. Re-introduce the style when an overlay
         button comes back. -->

    <style name="Widget.Dish.Pill" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/binding_pill_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/binding_pill_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/binding_pill_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/binding_pill_padding_vertical</item>
    </style>

    <style name="Widget.Dish.Pill.Icon" parent="">
        <item name="android:layout_width">@dimen/binding_pill_icon_size</item>
        <item name="android:layout_height">@dimen/binding_pill_icon_size</item>
        <item name="android:layout_marginEnd">@dimen/binding_pill_icon_gap</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

    <style name="Widget.Dish.Pill.Text" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.Dish.BodySmall</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.Dish.MicroLabel" parent="">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textAppearance">@style/TextAppearance.Dish.Label.Micro</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.Dish.Segment" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/config_segment_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/config_segment_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/binding_row_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/binding_row_padding_vertical</item>
        <item name="android:textAppearance">@style/TextAppearance.Dish.BodySmall</item>
        <item name="android:textColor">@color/binding_segment_text</item>
        <item name="android:background">@drawable/bg_binding_segment</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.Dish.Divider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/divider_height</item>
        <item name="android:background">@color/colorOutlineVariant</item>
    </style>

</resources>
