<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Material 3 base. The M2 `colorPrimaryVariant` / `colorSecondaryVariant`
         attributes intentionally dropped — they don't exist in the M3 token
         system (replaced by `colorPrimaryContainer` / `colorSecondaryContainer`
         which we now pin alongside the rest of the M3 container/variant
         family so widgets don't compute off-brand pastels from M3's default
         tonal palette).

         The theme is organised in seven blocks:
           1. Core colour slots (primary/surface/error/background)
           2. M3 surface + outline variants and tonal containers
           3. M3 surface container hierarchy (Lowest → Highest + Dim/Bright)
           4. M3 inverse + tertiary + scrim families
           5. Typography ramp (?attr/textAppearance*) — see the block-level
              comment for why labelLarge/display*/headlineLarge* stay
              unmapped.
           6. Shape ramp (?attr/shapeAppearanceCorner*) — backed by the
              ShapeAppearance.Dish.Corner.* styles defined at the bottom
              of this file.
           7. Window chrome + default widget styles (button + alert dialog
              overlay + chip). -->
    <style name="Theme.Dish" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- ── 1. Core colour slots ── -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSecondary">@color/colorPrimaryMid</item>
        <!-- colorOnSecondary mirrors colorOnPrimary because colorSecondary
             (cyan_700) has the same luminance as colorPrimaryDark — any
             future widget reading the Material on/bg pair gets 5.6:1
             contrast, well above WCAG AA's 4.5:1. -->
        <item name="colorOnSecondary">@color/colorOnPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorError">@color/colorError</item>
        <item name="android:colorBackground">@color/colorBackground</item>

        <!-- ── 2. M3 surface + outline variants and tonal containers ──
             Pinned so widgets that read these slots (dividers, switch
             tracks, alert dialog body bg, tonal button variants, FAB
             extended labels, error chip surfaces, MaterialDivider,
             LinearProgressIndicator track) don't fall back to M3's
             auto-derived greys/pastels. See colors.xml for the
             palette mapping.

             Containers are OPAQUE deep tones (signal_cyan_900 / red_900 /
             amber_900) rather than alpha-composited primaries; the
             on/container contrast guarantee assumes a fully-resolved
             container colour, and alpha containers break the guarantee
             under any non-default surface. -->
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        <item name="colorOutline">@color/colorOutline</item>
        <item name="colorOutlineVariant">@color/colorOutlineVariant</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>
        <item name="colorErrorContainer">@color/colorErrorContainer</item>
        <item name="colorOnErrorContainer">@color/colorOnErrorContainer</item>
        <!-- M3 elevation overlay disabled: the tonal overlay that
             Material applies to elevated surfaces would tint our dark
             navy cards with the cyan primary as their elevation rises,
             producing an off-brand violet/cyan wash. Every Dish card
             pins cardElevation to 0dp today, but disabling the
             mechanism here keeps a future contributor from accidentally
             surfacing the overlay by bumping elevation > 0.
             (Material 1.14 doesn't expose colorSurfaceTint as a theme
             attr — the mechanism is gated by elevationOverlayEnabled
             instead. Our semantic "icon container fill" token was
             renamed from colorSurfaceTint to colorIconContainerFill
             during the M3 audit so the names don't suggest a wiring
             that doesn't exist.) -->
        <item name="elevationOverlayEnabled">false</item>

        <!-- ── 3. M3 surface container hierarchy ──
             M3's replacement for elevation overlays as the way to communicate
             depth. Five "container" tones (Lowest → Highest) plus the
             orthogonal Dim/Bright pair. Pinned so M3-elevated surfaces
             (alert dialog body, bottom sheets, navigation bar, menu popups,
             date/time pickers, navigation drawer) inherit navy tones
             instead of M3's default tonal-palette math producing grey-blues.

             colorSurfaceDim aliases navy_800 (= colorSurface) here per M3
             dark-mode spec: surface and surfaceDim coincide in dark themes
             (the dim distinction matters for light themes where the page
             is bright). Our semantic `colorSurfaceDim` token in colors.xml
             still maps to navy_700 for legacy consumers (GamepadTouchView
             stick recess, empty-state surface) — the two coexist
             intentionally; see colors.xml. -->
        <item name="colorSurfaceContainerLowest">@color/colorSurfaceContainerLowest</item>
        <item name="colorSurfaceContainerLow">@color/colorSurfaceContainerLow</item>
        <item name="colorSurfaceContainer">@color/colorSurfaceContainer</item>
        <item name="colorSurfaceContainerHigh">@color/colorSurfaceContainerHigh</item>
        <item name="colorSurfaceContainerHighest">@color/colorSurfaceContainerHighest</item>
        <item name="colorSurfaceDim">@color/colorM3SurfaceDim</item>
        <item name="colorSurfaceBright">@color/colorSurfaceBright</item>

        <!-- ── 4. M3 inverse + tertiary ──
             Inverse: used by Material Snackbar's default surface. Our
             DishNotifications renderer skins the Snackbar background per
             severity, but any plain `Snackbar.make()` from a code path
             that hasn't been migrated reads these — pinning them means
             the fallback is brand-correct (light surface, navy text).

             Tertiary: the "complementary accent" slot. Amber pairs warm
             against the cool cyan primary; we collapse colorWarning into
             colorTertiary so the M3 tertiary role and the warning severity
             share a single source of truth instead of running parallel
             families.

             colorScrim is NOT pinned — Material 1.14 doesn't expose it as
             a theme attr (the M3 spec adds it, the library hasn't shipped
             it yet). The existing `colorOverlayScrim` resource backs the
             only scrim consumer today (low-power HUD); revisit when the
             attr arrives in Material 1.15+. -->
        <item name="colorSurfaceInverse">@color/colorSurfaceInverse</item>
        <item name="colorOnSurfaceInverse">@color/colorOnSurfaceInverse</item>
        <item name="colorPrimaryInverse">@color/colorPrimaryInverse</item>
        <item name="colorTertiary">@color/colorTertiary</item>
        <item name="colorOnTertiary">@color/colorOnTertiary</item>
        <item name="colorTertiaryContainer">@color/colorTertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/colorOnTertiaryContainer</item>

        <!-- ── 5. Typography ramp ──
             Route Material widgets that read ?attr/textAppearance* through
             Dish typography so MaterialAlertDialog titles, Snackbar bodies,
             chips, exposed-dropdown items, etc. render in the brand voice
             instead of M3 defaults.

             Intentionally unmapped:
               - labelLarge: the button-text slot. MaterialButton text style
                 is set directly via Widget.Dish.Button, and our Dish.Label
                 is the 11sp mono eyebrow — mapping it would force eyebrow
                 type onto Chip / NavigationBar / Menu widgets we'd want
                 readable. The dialog button bar inherits Widget.Dish.Button*
                 (which sets its own textAppearance) so this leaves no slot
                 unaccounted for in current consumers.
               - display* + headlineLarge/Medium: we drive hero numerals
                 + brand wordmarks via Dish.Hero / Dish.Display(.Large)
                 applied at the callsite. No M3 widget we use reads these
                 slots, so leaving them at the platform default avoids
                 surprises if one is later introduced.

             headlineSmall and titleLarge both map to Dish.Title.Large
             because MaterialAlertDialog reads one or the other depending
             on whether it's a centered/icon variant — unifying them
             means both render the same. -->
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Dish.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Dish.Body</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Dish.BodySmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Dish.Title.Large</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Dish.Title</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Dish.Title</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Dish.Title.Large</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Dish.Label</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Dish.Caption</item>

        <!-- ── 6. Shape ramp ──
             Material 3 widgets read `?attr/shapeAppearanceCornerSmall` etc.
             when picking corner radii — alert dialog corners, exposed
             dropdown menus, bottom sheets, the Snackbar surface, and FAB
             variants all flow through this ramp. Pinning the five slots
             to Dish corner dimens means a new M3 surface adopted later
             inherits our radii without a per-call override.

             Material 1.14 also keeps the legacy
             `shapeAppearanceSmallComponent` / `MediumComponent` /
             `LargeComponent` attrs around, but Theme.Material3 already
             defaults each of those to the corresponding Corner.* slot,
             so we don't need to set them ourselves. -->
        <item name="shapeAppearanceCornerExtraSmall">@style/ShapeAppearance.Dish.Corner.ExtraSmall</item>
        <item name="shapeAppearanceCornerSmall">@style/ShapeAppearance.Dish.Corner.Small</item>
        <item name="shapeAppearanceCornerMedium">@style/ShapeAppearance.Dish.Corner.Medium</item>
        <item name="shapeAppearanceCornerLarge">@style/ShapeAppearance.Dish.Corner.Large</item>
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.Dish.Corner.ExtraLarge</item>

        <!-- ── 7. Window chrome + default widget styles ──
             windowBackground stays pinned to the navy background so the
             pre-content frame doesn't flash a platform default. status /
             navigation bar colours are NOT set here: applyDishSystemBars
             (ActivityExtensions.kt) calls enableEdgeToEdge() with explicit
             SystemBarStyle.dark() for both bars, which forces dark scrim
             + light icons regardless of the device's day/night mode —
             without that override, SystemBarStyle.auto() would pick light
             scrim + dark icons in day mode, producing invisible dark icons
             on our dark navy chrome (Theme.Dish renders identically in
             day and night). The android:windowLightStatusBar /
             windowLightNavigationBar theme attrs are not pinned because
             the runtime SystemBarStyle.dark() takes precedence and works
             across the full minSdk range (the windowLight* attrs require
             API 23 / 27 respectively). -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <!-- Default MaterialButton style for the entire app -->
        <item name="materialButtonStyle">@style/Widget.Dish.Button</item>
        <!-- Default MaterialChip style — drives every chip the Controller
             card's inline pickers inflate (Type, Touchpad mode). Selected /
             unselected fill, stroke, text colour, ripple, state layer, and
             shape all flow through this style; the adapter only sets
             `isChecked` + click handler. -->
        <item name="chipStyle">@style/Widget.Dish.Chip</item>
        <!-- Branded chrome for MaterialAlertDialogBuilder so the two
             remaining stock dialogs (ConnectionsActivity's forget-BT
             confirmation + Bluetooth profile picker) match
             PairPinDialog's brand language instead of rendering with
             M3 default chrome. -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Dish.MaterialAlertDialog</item>
    </style>

    <!-- Filled button: cyan-dark background, dark navy text (colorOnPrimary).
         Sentence-case + no letter-tracking — M3 dropped the all-caps button
         convention universally. Strings supply their own capitalisation. -->
    <style name="Widget.Dish.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/colorPrimaryDark</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/colorPrimaryMid</item>
    </style>

    <!-- Outlined button: transparent bg, subtle border, light text. -->
    <style name="Widget.Dish.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="strokeColor">@color/colorOutline</item>
        <item name="strokeWidth">@dimen/border_thin</item>
        <item name="cornerRadius">@dimen/corner_button</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/colorPrimaryDark</item>
    </style>

    <!-- Custom dialog theme: transparent window background so the bg_pill
         surface's rounded corners + cyan outline are the only visible shape,
         dim behind so the activity recedes (matches the dim-on-low-power
         scrim alpha for a consistent floating-element treatment). Used by
         PairPinDialog.
         Parented at the M3 dialog theme so MaterialButton children inside
         pick up M3 ripple/state-layer treatments consistent with the rest
         of the app. -->
    <style name="Theme.Dish.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="materialButtonStyle">@style/Widget.Dish.Button</item>
    </style>

    <!-- ============================================================
         SHAPE RAMP — backs the ?attr/shapeAppearanceCorner* attrs above.

         Mapping rationale (size → semantic role):
           ExtraSmall (4dp)  → chip surfaces (assist/filter)
           Small      (6dp)  → button surfaces
           Medium     (8dp)  → card surfaces, alert dialog corners
           Large     (10dp)  → snackbar surface, large container
           ExtraLarge (20dp) → pill / floating banner surfaces

         Parented at the M3 ShapeAppearance.Material3.Corner.* styles so
         we inherit M3's corner-family default (rounded) and override
         only the size.
         ============================================================ -->
    <style name="ShapeAppearance.Dish.Corner.ExtraSmall" parent="ShapeAppearance.Material3.Corner.ExtraSmall">
        <item name="cornerSize">@dimen/corner_chip</item>
    </style>

    <style name="ShapeAppearance.Dish.Corner.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">@dimen/corner_button</item>
    </style>

    <style name="ShapeAppearance.Dish.Corner.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">@dimen/corner_card</item>
    </style>

    <style name="ShapeAppearance.Dish.Corner.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">@dimen/corner_notification</item>
    </style>

    <style name="ShapeAppearance.Dish.Corner.ExtraLarge" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSize">@dimen/corner_pill</item>
    </style>

    <!-- ============================================================
         MATERIAL ALERT DIALOG OVERLAY — registered on Theme.Dish above
         via materialAlertDialogTheme. Applied to every
         MaterialAlertDialogBuilder(this) constructed inside an Activity
         that uses Theme.Dish.

         Title / body styles are TextAppearances (matching what
         `materialAlertDialogTitleTextStyle` / `materialAlertDialogBodyTextStyle`
         expect — those attrs consume TextAppearance refs, not full
         Styles). The attrs are flattened directly (textSize / textColor /
         fontFamily / textStyle / letterSpacing) rather than nesting an
         `android:textAppearance` item — that nesting is meaningless inside
         a TextAppearance style and was a documented foot-gun before this
         pass (see text_appearance.xml block header for the `style="…"` vs
         `android:textAppearance` rule).

         Note: lineSpacingMultiplier is structurally lost in the dialog
         body — Material's MaterialAlertDialog applies the body style via
         setTextAppearance(), which doesn't carry lineSpacing through. If
         a future design requires dialog-body line spacing, override
         materialAlertDialogBodyTextStyle to a custom layout instead of
         a TextAppearance.

         Positive button goes filled (primary action); negative and
         neutral go outlined so multi-button bars (e.g. the forget-BT
         confirmation, which has three buttons) read as three peer
         choices rather than one "default" plus two text buttons.
         ============================================================ -->
    <style name="TextAppearance.Dish.Dialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textSize">@dimen/text_title_lg</item>
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Dish.Dialog.Body" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/colorMuted</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="ThemeOverlay.Dish.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.Dish.Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/TextAppearance.Dish.Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Dish.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Dish.Button.Outlined</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.Dish.Button.Outlined</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
    </style>
</resources>
