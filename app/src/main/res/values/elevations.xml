<?xml version="1.0" encoding="utf-8"?>
<!--
    ELEVATION TOKENS — semantic names for the resting heights in the
    Dish design system. Layouts and styles reference these instead of raw
    dp values so a global shadow-depth adjustment is a one-file change.

    The values resolve through the `size_N` primitive scale in
    `dimens_primitives.xml` (except `elevation_none`, which is the
    idiomatic literal 0dp — primitives intentionally exclude it; see the
    rationale at the top of `dimens_primitives.xml`).

    Tier guide:
      - none      — flat surfaces (cards on a page, list rows).
      - floating  — Snackbars, FABs, transient floating affordances.

    `elevation_raised` (2dp) and `elevation_modal` (12dp) were removed in
    the post-Phase-4 cleanup — no current callsite uses them. Re-introduce
    when a surface needs to pin to the canonical scale (see DESIGN_SYSTEM.md
    "When to add a new token").
-->
<resources>
    <dimen name="elevation_none">0dp</dimen>
    <dimen name="elevation_floating">@dimen/size_6</dimen>
</resources>
