<?xml version="1.0" encoding="utf-8"?>
<!--
    LIGHT-MODE SEMANTIC COLOR TOKENS — names by role, mapped to primitives
    in `colors_primitives.xml`. This is the file every layout XML,
    drawable, style, and Kotlin source consults at resource-resolution
    time when the device is in DAY mode (or the user has opted into
    the light theme via the in-app Appearance setting — AppCompatDelegate's
    night-mode flag drives Android's resource resolution the same way a
    system uiMode change does).

    The DARK-mode counterpart lives in `values-night/colors.xml` and
    overrides this file's bindings whenever the night qualifier wins.
    Both files share the SAME semantic names so every consumer (layouts,
    drawables, state-list colors, styles) reads the right tone for the
    current mode without callsite knowledge of which mode is active.

    Two families:
      - Material slots (`colorPrimary`, `colorOnSurface`, `colorSurfaceVariant`,
        the M3 container hierarchy `colorSurfaceContainer*`, the inverse
        family `colorInverseSurface` / `colorInverseOnSurface` /
        `colorInversePrimary`, the tertiary role `colorTertiary*`, etc.) —
        consumed by the Theme.Dish theme + every Material widget. The full
        M3 surface + container + tertiary + inverse family is pinned in
        both day and night files so M3 defaults never compute off-brand
        tones from the platform tonal palette.
      - Dish-specific roles (`colorMuted`, `colorCardStroke`,
        `colorOverlayScrim`, `colorIconContainerFill`) — named for the
        visual intent at the callsite.

    Light-mode design rationale:
      - Surfaces use the cool-tinted `cloud_*` ramp (faint blue-grey)
        rather than a pure neutral, so the brand's deep-space accent
        carries through both themes instead of feeling tacked-on in light.
      - Body text uses `navy_900` (the same primitive that backs the
        DARK theme's background) — the brand's darkest navy becomes the
        text colour in light mode, completing the inversion.
      - `colorPrimary` (signal_cyan_500) stays unchanged across both
        modes — the brand cyan is bright enough to read on white surfaces
        and saturated enough to read on the navy chrome. `colorPrimaryDark`
        (signal_cyan_700, the mid-saturation teal) backs filled buttons
        in both modes for the same reason.
      - The alpha-derived cyan family (signal_cyan_100/200/300) is also
        mode-neutral: composited over a light cloud surface, the same
        18%-alpha cyan produces a pale-cyan outline; composited over
        navy_800, it produces the same brand-cyan tint just on a darker
        base. Stroke / outline / icon-container fill resolve correctly
        in both directions without needing dedicated light primitives.
      - Tonal containers (Primary / Error / Tertiary) DO need dedicated
        light primitives because they must be OPAQUE — the M3 on/container
        contrast guarantee assumes a fully-resolved container colour.
        `signal_cyan_50` / `red_100` / `amber_100` back the light versions;
        their *_900 counterparts back the dark versions.

    If you're tempted to put a literal `#…` in a layout, look here first.
    A new semantic name with a primitive ref behind it is almost always
    the right answer.
-->
<resources>
    <!-- ===== Material surface + on-surface ===== -->
    <color name="colorBackground">@color/cloud_200</color>
    <color name="colorSurface">@color/cloud_50</color>
    <!-- colorOnPrimary stays navy_900 in BOTH modes: the primary fill
         (`colorPrimary` = signal_cyan_500) is bright cyan in both modes,
         so dark text reads on it regardless of the underlying surface. -->
    <color name="colorOnPrimary">@color/navy_900</color>
    <color name="colorOnSurface">@color/navy_900</color>

    <!-- ===== M3 surface + outline variants =====
         `colorOutlineVariant` uses a quiet cloud lift (cloud_400) rather
         than a cyan-alpha tint — that slot drives MaterialDivider, the
         unselected MaterialSwitch track, dropdown menu separators, and
         other structural dividers. Cyan on `colorOutline` (card strokes,
         focus rings) is load-bearing; cyan on every quiet structural
         element would bleed the accent everywhere. -->
    <color name="colorSurfaceVariant">@color/cloud_400</color>
    <color name="colorOnSurfaceVariant">@color/slate_500</color>
    <color name="colorOutlineVariant">@color/cloud_400</color>

    <!-- ===== M3 surface container hierarchy =====
         M3 light-mode spec ramps surface containers from the lightest
         (Lowest = page surface) up through progressively darker tints
         (Highest = most-elevated tier). The Dim/Bright pair is the
         orthogonal axis: `colorSurfaceDim` is *darker* than surface in
         light mode (it's the "recessed" companion); `colorSurfaceBright`
         is the lightest tone (sits at white).

         The legacy `colorSurfaceDim` token immediately below this block
         is the Dish-specific "slightly lifted from surface" role — it
         aliases `cloud_400` (the same tone as `colorSurfaceVariant`) so
         empty-state surfaces and the touchpad-stick recessed background
         still read as a single recessed tier in light mode. -->
    <color name="colorSurfaceContainerLowest">@color/cloud_50</color>
    <color name="colorSurfaceContainerLow">@color/cloud_100</color>
    <color name="colorSurfaceContainer">@color/cloud_200</color>
    <color name="colorSurfaceContainerHigh">@color/cloud_300</color>
    <color name="colorSurfaceContainerHighest">@color/cloud_400</color>
    <color name="colorM3SurfaceDim">@color/cloud_300</color>
    <color name="colorSurfaceBright">@color/cloud_50</color>

    <!-- ===== M3 inverse family =====
         Inverse pairs DARK against the light theme so the "you have a
         transient message" surface reads as a different elevation tier
         than the light cards behind it. The same primitives that back
         the *default* surface in dark mode (navy_900 / paper_50) back
         the *inverse* surface here — the inversion is symmetric. -->
    <color name="colorSurfaceInverse">@color/navy_900</color>
    <color name="colorOnSurfaceInverse">@color/paper_50</color>
    <color name="colorPrimaryInverse">@color/signal_cyan_500</color>

    <!-- ===== Primary + variants =====
         Brand cyan reads on both themes. signal_cyan_500 (bright cyan)
         is `colorPrimary`; signal_cyan_700 (mid-saturation teal) backs
         filled buttons and the pressed/disabled state via
         `colorPrimaryDark` / `colorPrimaryMid`. -->
    <color name="colorPrimary">@color/signal_cyan_500</color>
    <color name="colorPrimaryDark">@color/signal_cyan_700</color>
    <color name="colorPrimaryMid">@color/signal_cyan_700</color>

    <!-- ===== M3 tonal containers =====
         OPAQUE light tones (signal_cyan_50 / red_100 / amber_100) — the
         M3 on/container contrast guarantee assumes a fully-resolved
         container colour. The `*OnContainer` companions resolve to
         `navy_900` for WCAG-AA-compliant dark text on the light fill. -->
    <color name="colorPrimaryContainer">@color/signal_cyan_50</color>
    <color name="colorOnPrimaryContainer">@color/navy_900</color>
    <color name="colorErrorContainer">@color/red_100</color>
    <color name="colorOnErrorContainer">@color/red_900</color>

    <!-- ===== M3 tertiary role =====
         Amber pairs warm against the cool cyan primary; the M3 tertiary
         role and the warning severity share a single source of truth. -->
    <color name="colorTertiary">@color/amber_500</color>
    <color name="colorOnTertiary">@color/navy_900</color>
    <color name="colorTertiaryContainer">@color/amber_100</color>
    <color name="colorOnTertiaryContainer">@color/amber_900</color>

    <!-- ===== Secondary chrome ===== -->
    <color name="colorMuted">@color/slate_500</color>
    <!-- signal_cyan_300 = signal cyan @ ~18% alpha. Composited over the
         light cloud surfaces, this resolves to a pale-cyan outline that
         carries the brand accent without overpowering the page. -->
    <color name="colorOutline">@color/signal_cyan_300</color>
    <!-- signal_cyan_200 = signal cyan @ ~12% alpha. Composited over the
         light cloud surfaces, this is the subtle cyan-tinted card stroke
         that anchors every Widget.Dish.Card. -->
    <color name="colorCardStroke">@color/signal_cyan_200</color>
    <!-- signal_cyan_100 = signal cyan @ ~6% alpha. Faintest cyan tint —
         the fill behind the Settings-row icon container. -->
    <color name="colorIconContainerFill">@color/signal_cyan_100</color>
    <!-- Brand-specific "slightly lifted from surface" role used by empty
         states + the touchpad-stick recessed background. Not wired to
         M3's `colorSurfaceDim` attr — that slot reads `colorM3SurfaceDim`
         above. cloud_400 keeps the recessed tier distinct from the
         page surface (cloud_200) without going as dark as the variant
         containers. -->
    <color name="colorSurfaceDim">@color/cloud_400</color>

    <!-- ===== Severity =====
         Status tones are shared across both modes — green / red / amber
         500 read on light and dark backgrounds. -->
    <color name="colorSuccess">@color/green_500</color>
    <color name="colorError">@color/red_500</color>
    <color name="colorWarning">@color/amber_500</color>

    <!-- ===== Scrim =====
         Full-screen dim overlay (e.g. low-power mode) — black @ ~80% alpha
         in BOTH modes. The scrim's job is to communicate "the screen
         is intentionally dimmed", which reads identically on light and
         dark page surfaces. Distinct from M3's `colorScrim` (which is
         opaque and consumer-tinted); this token carries the dim already
         so the low-power HUD can apply it as a single background. -->
    <color name="colorOverlayScrim">@color/ink_900_a80</color>
</resources>
