<?xml version="1.0" encoding="utf-8"?>
<!--
    SEMANTIC COLOR TOKENS — names by role, mapped to primitives in
    `colors_primitives.xml`. This is the file every layout XML, drawable,
    style, and Kotlin source should reference.

    Three families:
      - Material slots (`colorPrimary`, `colorOnSurface`, etc.) — consumed
        by the Theme.Dish theme + every Material widget.
      - Dish-specific roles (`colorMuted`, `colorCardStroke`,
        `colorOverlayScrim`, `colorSurfaceTint`) — named for the visual
        intent at the callsite.
      - Severity rails (`colorRail_info / _success / _warn / _error`) —
        the leading-rail color for the four `notification_bg_*` drawables.

    If you're tempted to put a literal `#…` in a layout, look here first.
    A new semantic name with a primitive ref behind it is almost always
    the right answer.
-->
<resources>
    <!-- ===== Material surface + on-surface ===== -->
    <color name="colorBackground">@color/navy_900</color>
    <color name="colorSurface">@color/navy_800</color>
    <color name="colorOnPrimary">@color/navy_900</color>
    <color name="colorOnSurface">@color/paper_50</color>

    <!-- ===== Primary + variants ===== -->
    <color name="colorPrimary">@color/signal_cyan_500</color>
    <color name="colorPrimaryDark">@color/signal_cyan_700</color>
    <color name="colorPrimaryMid">@color/signal_cyan_700</color>

    <!-- ===== Secondary chrome ===== -->
    <color name="colorMuted">@color/slate_300</color>
    <!-- Web uses rgba(79,227,255,0.18) for the outline; ARGB equivalent is
         signal cyan at ~18% alpha (signal_cyan_300). -->
    <color name="colorOutline">@color/signal_cyan_300</color>
    <!-- Primary at ~12% alpha for card stroke. -->
    <color name="colorCardStroke">@color/signal_cyan_200</color>
    <!-- Primary at ~6% alpha — fill for the Settings-row icon container
         and other subtle surface tints. -->
    <color name="colorSurfaceTint">@color/signal_cyan_100</color>
    <!-- Subtle surface variant for empty states (mirrors tn-deep). -->
    <color name="colorSurfaceDim">@color/navy_700</color>

    <!-- ===== Severity ===== -->
    <color name="colorSuccess">@color/green_500</color>
    <color name="colorError">@color/red_500</color>
    <color name="colorWarning">@color/amber_500</color>

    <!-- ===== Notification rails ===== -->
    <!-- Per-severity leading-rail color used by notification_bg_*.xml.
         Aliased so a future severity-palette tweak (e.g. softer warn) is
         one file, not four drawables. -->
    <color name="colorRail_info">@color/signal_cyan_500</color>
    <color name="colorRail_success">@color/green_500</color>
    <color name="colorRail_warn">@color/amber_500</color>
    <color name="colorRail_error">@color/red_500</color>

    <!-- ===== Disabled affordance fill =====
         Muted slate at 40% alpha — for general disabled icons + chips that
         don't pivot to a more specific state-list. Disabled text uses
         the @color/text_disabled state-list instead, which fades the
         on-surface paper tone. -->
    <color name="colorDisabled">@color/slate_300_a40</color>

    <!-- ===== Scrims + absolutes ===== -->
    <!-- Full-screen dim overlay (e.g. low-power mode) — black @ ~80% alpha. -->
    <color name="colorOverlayScrim">@color/ink_900_a80</color>
    <color name="black">@color/ink_900</color>
    <color name="white">@color/paper_pure</color>
</resources>
