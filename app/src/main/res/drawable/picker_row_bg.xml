<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the per-connection picker row inside an expanded slot
     card. State-list keyed by android:selected — selected = "this slot is
     currently bound to this connection" so the border flips to colorPrimary;
     otherwise muted colorOutline. The adapter just sets `view.isSelected =
     bound`; no hand-rolled GradientDrawable per row. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackground" />
            <corners android:radius="@dimen/corner_picker_row" />
            <stroke android:width="@dimen/border_thin" android:color="@color/colorPrimary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackground" />
            <corners android:radius="@dimen/corner_picker_row" />
            <stroke android:width="@dimen/border_thin" android:color="@color/colorOutline" />
        </shape>
    </item>
</selector>
