<?xml version="1.0" encoding="utf-8"?>
<!-- Outlined circle + checkmark, stroked over a transparent fill so a flat tint
     (app:tint / imageTintList) colours the ring and the tick while the centre stays
     see-through. A filled disc would read as a solid coloured circle. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#00000000"
        android:pathData="M12,21 A9,9 0 1 1 12,3 A9,9 0 1 1 12,21 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2" />
    <path
        android:fillColor="#00000000"
        android:pathData="M7.8,12.3 L10.7,15.2 L16.2,9"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2" />
</vector>
