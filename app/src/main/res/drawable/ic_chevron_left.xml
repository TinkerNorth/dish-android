<!-- v6 brand "chevron-left" glyph: open V at 64u viewport, stroked at 4u
     to match the navigation-set stroke ladder (chevrons stay thinner than
     the 6u feature glyphs so they read as wayfinding chrome).

     autoMirrored is true so the chevron flips to a right-pointing V in
     RTL layouts (the Toolbar's back affordance is direction-anchored to
     the locale, not the source artwork). Without this attr, an Arabic /
     Hebrew user would see a left-chevron on the toolbar end where the
     back affordance lives, pointing away from "back". -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="64"
    android:viewportHeight="64"
    android:autoMirrored="true">
    <path
        android:strokeColor="#8FCFE3"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M40,12 L22,32 L40,52" />
</vector>
