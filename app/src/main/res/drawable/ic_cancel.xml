     the ring and the cross while the centre stays see-through (mirrors
     ic_check_circle). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#00000000"
        android:pathData="M12,21 A9,9 0 1 1 12,3 A9,9 0 1 1 12,21 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2" />
    <path
        android:fillColor="#00000000"
        android:pathData="M9.2,9.2 L14.8,14.8 M14.8,9.2 L9.2,14.8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="2" />
</vector>
