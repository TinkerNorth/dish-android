<?xml version="1.0" encoding="utf-8"?>
<!-- Background for the pickable chip used in the controller card's inline
     pickers (Type, Touchpad mode). State-list keyed by android:selected so
     the adapter only has to call `view.isSelected = true/false` instead of
     hand-rolling a GradientDrawable per chip. Border + corner radius mirror
     the previous programmatic shape exactly. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimary" />
            <corners android:radius="@dimen/corner_chip" />
            <stroke android:width="@dimen/border_thin" android:color="@color/colorOutline" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorBackground" />
            <corners android:radius="@dimen/corner_chip" />
            <stroke android:width="@dimen/border_thin" android:color="@color/colorOutline" />
        </shape>
    </item>
</selector>
