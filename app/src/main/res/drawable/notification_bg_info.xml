<?xml version="1.0" encoding="utf-8"?>
<!--
    Snackbar background for INFO + SUCCESS severities — rounded surface with
    a colorPrimary leading rail. One of four severity-keyed variants used by
    `DishNotifications.applyDishTheme`; previously built imperatively as a
    `LayerDrawable(GradientDrawable(), GradientDrawable())` per notification.

    Layer 1 is the full-bleed surface (rounded rect + outline stroke). Layer 2
    is the leading rail, sized via `android:width` + `android:gravity="start"`
    so the rail mirrors to the trailing edge automatically under RTL — same
    behaviour the prior `Gravity.START or Gravity.FILL_VERTICAL` code path
    produced. The rail's corner radii are only on the leading edge (top-left
    + bottom-left in LTR) so it tucks into the surface's rounded shoulder.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorSurface" />
            <corners android:radius="@dimen/corner_notification" />
            <stroke android:width="@dimen/border_thin" android:color="@color/colorOutline" />
        </shape>
    </item>

    <item
        android:width="@dimen/notification_rail_width"
        android:gravity="start">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorPrimary" />
            <corners
                android:topLeftRadius="@dimen/corner_notification"
                android:bottomLeftRadius="@dimen/corner_notification"
                android:topRightRadius="0dp"
                android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
