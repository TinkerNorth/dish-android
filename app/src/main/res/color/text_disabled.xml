<?xml version="1.0" encoding="utf-8"?>
<!-- Text color that flips to the disabled fade when its host is disabled.
     Applied via android:textColor="@color/text_disabled" on TextViews that
     need to dim with their enclosing card / button / switch. The disabled
     branch holds the on-surface hue but drops to 40% alpha so the type
     stays recognizably the same shade, just muted. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/colorTextDisabled" />
    <item android:color="@color/colorOnSurface" />
</selector>
