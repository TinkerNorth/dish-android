<?xml version="1.0" encoding="utf-8"?>
<!-- Tint color for interactive icons — the cyan accent at rest, fading to
     the muted slate when the host control is disabled. Applied via
     app:tint="@color/icon_interactive" on ImageViews + ImageButtons that
     should read as actionable. Pair with android:enabled on the parent. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false" android:color="@color/colorMuted" />
    <item android:color="@color/colorPrimary" />
</selector>
