    <string name="donate_title">Apoyar Dish</string>
    <string name="donate_eyebrow">Apoya el proyecto</string>
    <string name="donate_h1">Dish funciona con café y buena voluntad.</string>
    <string name="donate_lead">Dish, Satellite y cada cliente de Dish son gratis, código abierto, sin anuncios y sin analíticas. Sin funciones de pago, sin upselling y sin planes de nada de eso. Las donaciones son lo que los mantienen así.</string>
