<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/colorCardStroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header row: icon + name + status dot ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivControllerType"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_gamepad"
                app:tint="@color/colorPrimary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvControllerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSlotStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/colorMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ── Battery indicator (Task 1.2): icon + percentage ── -->
            <LinearLayout
                android:id="@+id/llBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <!-- contentDescription is set dynamically in ControllerAdapter
                     (level + charging state) so screen readers announce the
                     actual value; tools:ignore silences the static-text lint. -->
                <!-- No tint: the battery glyphs are intentionally two-tone
                     (teal hull + white overlay). bindBattery() swaps in the
                     charge-ladder rung; only the percentage text goes red. -->
                <ImageView
                    android:id="@+id/ivBattery"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_battery"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/tvBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:textColor="@color/colorMuted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- v6 brand connection-target glyph. Mirrors the row this slot
                 is bound to over on activity_connections.xml — a satellite
                 row's icon family is satellite, a Bluetooth row's is the
                 Berkana rune. Painted in ControllerAdapter.bind() from the
                 slot's boundStatus; hidden when unbound. -->
            <ImageView
                android:id="@+id/ivBoundKind"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:visibility="gone"
                android:src="@drawable/ic_satellite" />

            <View
                android:id="@+id/dotStatus"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/dot_circle" />

            <ImageView
                android:id="@+id/ivOpenGamepadQuick"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="2dp"
                android:src="@drawable/ic_open_gamepad"
                android:contentDescription="@string/desc_open_gamepad"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:tint="@color/colorPrimary" />

            <ImageView
                android:id="@+id/ivChevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@string/desc_expand"
                app:tint="@color/colorMuted" />
        </LinearLayout>

        <!-- ── Expandable body: bind-to-connection picker + actions ── -->
        <LinearLayout
            android:id="@+id/llBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/slot_output_to_label"
                android:textColor="@color/colorMuted"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.12"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:id="@+id/llConnectionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnbind"
                style="@style/Widget.Dish.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/action_unbind"
                android:textAllCaps="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenGamepad"
                style="@style/Widget.Dish.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/action_open_gamepad"
                android:textAllCaps="false"
                app:icon="@drawable/ic_open_gamepad"
                app:iconGravity="textStart"
                app:iconTint="@color/colorOnSurface"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenTouchpad"
                style="@style/Widget.Dish.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/action_open_touchpad"
                android:textAllCaps="false"
                app:icon="@drawable/ic_open_touchpad"
                app:iconGravity="textStart"
                app:iconTint="@color/colorOnSurface"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
