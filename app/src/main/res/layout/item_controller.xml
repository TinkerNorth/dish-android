<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardRoot"
    style="@style/Widget.Dish.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_margin_bottom">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header row: icon + name + status dot ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivControllerType"
                android:layout_width="@dimen/icon_controller"
                android:layout_height="@dimen/icon_controller"
                android:src="@drawable/ic_gamepad"
                app:tint="@color/colorPrimary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_2xl"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvControllerName"
                    style="@style/TextAppearance.Dish.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvSlotStatus"
                    style="@style/TextAppearance.Dish.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- ── Battery indicator (Task 1.2): icon + percentage ── -->
            <LinearLayout
                android:id="@+id/llBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <!-- contentDescription is set dynamically in ControllerAdapter
                     (level + charging state) so screen readers announce the
                     actual value; tools:ignore silences the static-text lint. -->
                <!-- No tint: the battery glyphs are intentionally two-tone
                     (teal hull + white overlay). bindBattery() swaps in the
                     charge-ladder rung; only the percentage text goes red. -->
                <ImageView
                    android:id="@+id/ivBattery"
                    android:layout_width="@dimen/icon_battery"
                    android:layout_height="@dimen/icon_battery"
                    android:src="@drawable/ic_battery"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/tvBattery"
                    style="@style/TextAppearance.Dish.BodySmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/size_3" />
            </LinearLayout>

            <!-- v6 brand connection-target glyph. Mirrors the row this slot
                 is bound to over on activity_connections.xml — a satellite
                 row's icon family is satellite, a Bluetooth row's is the
                 Berkana rune. Painted in ControllerAdapter.bind() from the
                 slot's boundStatus; hidden when unbound. -->
            <ImageView
                android:id="@+id/ivBoundKind"
                android:layout_width="@dimen/icon_brand_sm"
                android:layout_height="@dimen/icon_brand_sm"
                android:layout_marginEnd="@dimen/spacing_md"
                android:contentDescription="@null"
                android:visibility="gone"
                android:src="@drawable/ic_satellite" />

            <View
                android:id="@+id/dotStatus"
                style="@style/Widget.Dish.StatusDot.Large"
                android:layout_marginEnd="@dimen/spacing_xl" />

            <ImageView
                android:id="@+id/ivOpenGamepadQuick"
                android:layout_width="@dimen/icon_action"
                android:layout_height="@dimen/icon_action"
                android:padding="@dimen/size_2"
                android:src="@drawable/ic_open_gamepad"
                android:contentDescription="@string/desc_open_gamepad"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:tint="@color/colorPrimary" />

            <ImageView
                android:id="@+id/ivChevron"
                android:layout_width="@dimen/icon_chevron_lg"
                android:layout_height="@dimen/icon_chevron_lg"
                android:layout_marginStart="@dimen/spacing_sm"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@string/desc_expand"
                app:tint="@color/icon_secondary" />
        </LinearLayout>

        <!-- ── Expandable body: bind-to-connection picker + actions ── -->
        <LinearLayout
            android:id="@+id/llBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/card_padding_horizontal"
            android:paddingBottom="@dimen/card_padding_bottom"
            android:visibility="gone">

            <TextView
                style="@style/TextAppearance.Dish.Label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/slot_output_to_label"
                android:paddingBottom="@dimen/picker_section_padding_bottom" />

            <LinearLayout
                android:id="@+id/llConnectionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnbind"
                style="@style/Widget.Dish.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/picker_section_margin_top"
                android:text="@string/action_unbind"
                android:textAllCaps="false"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenGamepad"
                style="@style/Widget.Dish.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/picker_section_margin_top"
                android:text="@string/action_open_gamepad"
                android:textAllCaps="false"
                app:icon="@drawable/ic_open_gamepad"
                app:iconGravity="textStart"
                app:iconTint="@color/colorOnSurface"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenTouchpad"
                style="@style/Widget.Dish.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/picker_section_margin_top"
                android:text="@string/action_open_touchpad"
                android:textAllCaps="false"
                app:icon="@drawable/ic_open_touchpad"
                app:iconGravity="textStart"
                app:iconTint="@color/colorOnSurface"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
