<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen dim overlay for low-power mode (screen dimmed via window
     brightness; this scrim + HUD float over everything and consume the
     wake-tap). The streaming hint / pre-dim countdown chip lives in
     overlay_low_power_chip, docked in each screen's content column so it
     pushes content up instead of floating over it.
     View IDs preserved so LowPowerManager.Views still binds. -->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <FrameLayout
        android:id="@+id/flLowPowerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorOverlayScrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                style="@style/TextAppearance.Dish.Label.Accent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/low_power"
                android:textStyle="bold"
                android:letterSpacing="0.32" />

            <View
                android:layout_width="@dimen/size_56"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@color/colorOutline" />

            <TextView
                android:id="@+id/tvLowPowerTime"
                style="@style/TextAppearance.Dish.Hero"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:text="@string/low_power_clock_placeholder" />

            <View
                android:layout_width="@dimen/size_56"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:background="@color/colorOutline" />

            <TextView
                android:id="@+id/tvLowPowerStatus"
                style="@style/TextAppearance.Dish.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:text="@string/low_power_status_idle" />

            <TextView
                android:id="@+id/tvLowPowerDimBody"
                style="@style/TextAppearance.Dish.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:maxWidth="@dimen/low_power_dim_body_max_width"
                android:gravity="center_horizontal"
                android:text="@string/low_power_dim_body" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.Dish.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/size_32"
            android:alpha="0.7"
            android:background="@drawable/bg_pill"
            android:paddingHorizontal="@dimen/spacing_4xl"
            android:paddingVertical="@dimen/spacing_md"
            android:text="@string/low_power_tap_to_wake" />
    </FrameLayout>
</merge>
