<?xml version="1.0" encoding="utf-8"?>
<!-- Rebuilt in the v6 deep-space cyan idiom: floating bg_pill banner for the
     pre-dim countdown + a HUD-style dim overlay with letter-spaced monospace
     labels sandwiching the clock and a faint "TAP TO WAKE" affordance.
     View IDs and root types are preserved so LowPowerManager.Views still binds.
-->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Countdown banner (shown ~5s before the dim kicks in) ─────────── -->
    <LinearLayout
        android:id="@+id/llCountdownBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/spacing_6xl"
        android:background="@drawable/bg_pill"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_5xl"
        android:paddingVertical="@dimen/spacing_lg"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/low_power_in"
            android:textColor="@color/colorMuted"
            android:textSize="@dimen/text_body_sm"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:layout_marginEnd="@dimen/spacing_lg" />

        <TextView
            android:id="@+id/tvCountdownSeconds"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/size_24"
            android:gravity="center"
            android:text="@string/low_power_countdown_placeholder"
            android:textColor="@color/colorPrimary"
            android:textSize="@dimen/text_display"
            android:textStyle="bold"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/low_power_seconds_suffix"
            android:textColor="@color/colorMuted"
            android:textSize="@dimen/text_body_lg"
            android:fontFamily="monospace"
            android:layout_marginStart="@dimen/size_2" />
    </LinearLayout>

    <!-- ── Full-screen dim overlay when in low-power mode ───────────────── -->
    <FrameLayout
        android:id="@+id/flLowPowerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorOverlayScrim"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Centered HUD stack: brand label, clock, status. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/low_power"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.32" />

            <!-- Thin cyan-tinted rule under the section label. -->
            <View
                android:layout_width="@dimen/size_56"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@color/colorOutline" />

            <TextView
                android:id="@+id/tvLowPowerTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:text="@string/low_power_clock_placeholder"
                android:textColor="@color/colorPrimary"
                android:textSize="@dimen/text_hero"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.04" />

            <!-- Twin to the rule above the clock; brackets the time visually. -->
            <View
                android:layout_width="@dimen/size_56"
                android:layout_height="@dimen/divider_height"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:background="@color/colorOutline" />

            <TextView
                android:id="@+id/tvLowPowerStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:text="@string/low_power_status_idle"
                android:textColor="@color/colorMuted"
                android:textSize="@dimen/text_body_sm"
                android:fontFamily="monospace"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Faint affordance — screen is dimmed to ~1% brightness so this
             reads as a hint, not a CTA. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/size_32"
            android:alpha="0.7"
            android:background="@drawable/bg_pill"
            android:paddingHorizontal="@dimen/spacing_4xl"
            android:paddingVertical="@dimen/spacing_md"
            android:text="@string/low_power_tap_to_wake"
            android:textColor="@color/colorMuted"
            android:textSize="@dimen/text_label"
            android:fontFamily="monospace"
            android:letterSpacing="0.18" />
    </FrameLayout>
</merge>
