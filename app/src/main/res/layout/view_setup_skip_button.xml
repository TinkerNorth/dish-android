<?xml version="1.0" encoding="utf-8"?>
<!-- Top-right Skip shared by every setup toolbar. Added as a toolbar child view
     rather than a menu item so it survives setSupportActionBar, which would route a
     menu item's clicks past a toolbar listener. -->
<com.google.android.material.button.MaterialButton xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/btnSetupSkip"
    style="@style/Widget.Dish.Button.Text"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="end"
    android:text="@string/setup_action_skip" />
