<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/colorSurface">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/pairing_dialog_legacy_title"
        android:textColor="@color/colorOnSurface"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/pairing_dialog_legacy_message"
        android:textColor="@color/colorMuted" />

    <EditText
        android:id="@+id/et_pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/pairing_dialog_legacy_pin_hint"
        android:inputType="number"
        android:maxLength="4"
        android:gravity="center"
        android:textSize="24sp"
        android:textColor="@color/colorOnSurface"
        android:textColorHint="@color/colorMuted"
        android:letterSpacing="0.5"
        android:fontFamily="monospace" />

</LinearLayout>
