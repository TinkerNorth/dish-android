<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivDestIcon"
            android:layout_width="@dimen/config_section_icon_size"
            android:layout_height="@dimen/config_section_icon_size"
            android:layout_marginEnd="@dimen/config_section_icon_gap"
            android:importantForAccessibility="no"
            app:tint="@color/colorMuted" />

        <TextView
            android:id="@+id/tvDestLabel"
            style="@style/TextAppearance.Dish.Label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAllCaps="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/config_section_header_gap"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/hostDropdown"
            style="@style/Widget.Dish.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start|center_vertical"
            app:icon="@drawable/ic_chevron_down"
            app:iconGravity="end"
            app:iconTint="@color/colorMuted" />

        <LinearLayout
            android:id="@+id/legendSatellite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.Dish.MicroLabel"
                    android:layout_width="@dimen/binding_legend_label_column_width"
                    android:text="@string/picker_type_playstation" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:divider="@drawable/binding_pill_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:showDividers="middle">

                    <LinearLayout
                        style="@style/Widget.Dish.Pill"
                        android:background="@drawable/bg_binding_pill_cap">

                        <ImageView
                            style="@style/Widget.Dish.Pill.Icon"
                            android:src="@drawable/ic_motion"
                            app:tint="@color/colorOnSurfaceVariant" />

                        <TextView
                            style="@style/Widget.Dish.Pill.Text"
                            android:text="@string/binding_func_gyro"
                            android:textColor="@color/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/Widget.Dish.Pill"
                        android:background="@drawable/bg_binding_pill_cap">

                        <ImageView
                            style="@style/Widget.Dish.Pill.Icon"
                            android:src="@drawable/ic_touchpad"
                            app:tint="@color/colorOnSurfaceVariant" />

                        <TextView
                            style="@style/Widget.Dish.Pill.Text"
                            android:text="@string/binding_func_touchpad"
                            android:textColor="@color/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/config_legend_row_gap"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.Dish.MicroLabel"
                    android:layout_width="@dimen/binding_legend_label_column_width"
                    android:text="@string/picker_type_xbox" />

                <LinearLayout
                    style="@style/Widget.Dish.Pill"
                    android:background="@drawable/bg_binding_pill_cap">

                    <ImageView
                        style="@style/Widget.Dish.Pill.Icon"
                        android:src="@drawable/ic_rumble"
                        app:tint="@color/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.Dish.Pill.Text"
                        android:text="@string/binding_func_rumble"
                        android:textColor="@color/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/config_legend_row_gap"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.Dish.MicroLabel"
                    android:layout_width="@dimen/binding_legend_label_column_width"
                    android:text="@string/binding_dest_host" />

                <LinearLayout
                    style="@style/Widget.Dish.Pill"
                    android:background="@drawable/bg_binding_pill_cap">

                    <ImageView
                        style="@style/Widget.Dish.Pill.Icon"
                        android:src="@drawable/ic_mouse"
                        app:tint="@color/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.Dish.Pill.Text"
                        android:text="@string/binding_func_mouse"
                        android:textColor="@color/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/legendBt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.Dish.MicroLabel"
                    android:layout_width="@dimen/binding_legend_label_column_width"
                    android:text="@string/binding_dest_carries" />

                <LinearLayout
                    style="@style/Widget.Dish.Pill"
                    android:background="@drawable/bg_binding_pill_cap">

                    <ImageView
                        style="@style/Widget.Dish.Pill.Icon"
                        android:src="@drawable/ic_rumble"
                        app:tint="@color/colorOnSurfaceVariant" />

                    <TextView
                        style="@style/Widget.Dish.Pill.Text"
                        android:text="@string/binding_func_rumble"
                        android:textColor="@color/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/config_legend_row_gap"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.Dish.MicroLabel"
                    android:layout_width="@dimen/binding_legend_label_column_width"
                    android:text="@string/binding_dest_no_channel" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:divider="@drawable/binding_pill_gap"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:showDividers="middle">

                    <LinearLayout
                        style="@style/Widget.Dish.Pill"
                        android:alpha="0.6"
                        android:background="@drawable/bg_binding_pill_off">

                        <ImageView
                            style="@style/Widget.Dish.Pill.Icon"
                            android:src="@drawable/ic_motion"
                            app:tint="@color/colorMuted" />

                        <TextView
                            style="@style/Widget.Dish.Pill.Text"
                            android:text="@string/binding_func_gyro"
                            android:textColor="@color/colorMuted" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/Widget.Dish.Pill"
                        android:alpha="0.6"
                        android:background="@drawable/bg_binding_pill_off">

                        <ImageView
                            style="@style/Widget.Dish.Pill.Icon"
                            android:src="@drawable/ic_touchpad"
                            app:tint="@color/colorMuted" />

                        <TextView
                            style="@style/Widget.Dish.Pill.Text"
                            android:text="@string/binding_func_touchpad"
                            android:textColor="@color/colorMuted" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/Widget.Dish.Pill"
                        android:alpha="0.6"
                        android:background="@drawable/bg_binding_pill_off">

                        <ImageView
                            style="@style/Widget.Dish.Pill.Icon"
                            android:src="@drawable/ic_mouse"
                            app:tint="@color/colorMuted" />

                        <TextView
                            style="@style/Widget.Dish.Pill.Text"
                            android:text="@string/binding_func_mouse"
                            android:textColor="@color/colorMuted" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/TextAppearance.Dish.BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/binding_dest_bt_note" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/noHostsGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManage"
                style="@style/Widget.Dish.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:text="@string/binding_manage_destinations"
                app:icon="@drawable/ic_satellite"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/spacing_lg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_2xl"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm"
                android:paddingBottom="@dimen/config_legend_row_gap">

                <ImageView
                    android:layout_width="@dimen/config_empty_glyph_size"
                    android:layout_height="@dimen/config_empty_glyph_size"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_satellite_off"
                    app:tint="@color/colorMuted" />

                <TextView
                    style="@style/TextAppearance.Dish.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/binding_no_hosts_title" />

                <TextView
                    android:id="@+id/tvNoHostsBody"
                    style="@style/TextAppearance.Dish.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center"
                    android:textColor="@color/colorOnSurfaceVariant" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
