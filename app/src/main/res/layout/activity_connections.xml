<?xml version="1.0" encoding="utf-8"?>
<!-- CoordinatorLayout root: required by Material Snackbar's swipe-to-dismiss,
     and a drop-in replacement for the previous FrameLayout (every child uses
     match_parent / wrap_content + optional layout_gravity). The dim-screen
     overlay still sits on top of the existing content because it's included
     last in document order. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBackground"
            app:title="@string/title_connections"
            app:titleTextColor="@color/colorOnSurface"
            app:navigationIcon="@drawable/ic_chevron_left" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="@dimen/spacing_5xl"
            android:paddingVertical="@dimen/spacing_3xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Satellite section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- v6 brand satellite glyph — same icon family used in the
                         satellite/web dashboard and dish-mac SectionHeader so a
                         user moving between clients sees the same iconography. -->
                    <ImageView
                        android:layout_width="@dimen/icon_section_header"
                        android:layout_height="@dimen/icon_section_header"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_satellite" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_satellites"
                        android:textColor="@color/colorPrimary"
                        android:textSize="@dimen/text_label"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSatelliteScan"
                        style="@style/Widget.Dish.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_scan"
                        android:textAllCaps="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llSatelliteList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_md" />

                <TextView
                    android:id="@+id/tvSatelliteEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/discovery_empty_never_scanned"
                    android:textColor="@color/colorMuted"
                    android:textSize="@dimen/text_body_sm"
                    android:paddingVertical="@dimen/spacing_xl"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginVertical="@dimen/spacing_5xl"
                    android:background="@color/colorOutline" />

                <!-- ── Bluetooth section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_section_header"
                        android:layout_height="@dimen/icon_section_header"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bluetooth" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/section_bluetooth_hosts"
                        android:textColor="@color/colorPrimary"
                        android:textSize="@dimen/text_label"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBtAdd"
                        style="@style/Widget.Dish.Button.Outlined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_add"
                        android:textAllCaps="false" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llBtList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/spacing_md" />

                <TextView
                    android:id="@+id/tvBtEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/bt_hosts_empty"
                    android:textColor="@color/colorMuted"
                    android:textSize="@dimen/text_body_sm"
                    android:paddingVertical="@dimen/spacing_xl" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Low-power overlays (countdown banner + dim screen). Included last so
         the dim FrameLayout sits on top, identical to activity_main.xml. -->
    <include layout="@layout/overlay_low_power" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
