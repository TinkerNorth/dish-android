<?xml version="1.0" encoding="utf-8"?>
<!-- CoordinatorLayout root: required by Material Snackbar's swipe-to-dismiss,
     and a drop-in replacement for the previous FrameLayout (every child uses
     match_parent / wrap_content + optional layout_gravity). The dim-screen
     overlay still sits on top of the existing content because it's included
     last in document order. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.Dish.Toolbar"
            android:layout_width="match_parent"
            app:title="@string/title_connections">

            <include
                layout="@layout/view_donate_heart_button"
                android:layout_width="@dimen/icon_settings_button"
                android:layout_height="@dimen/icon_settings_button"
                android:layout_gravity="end" />
        </com.google.android.material.appbar.MaterialToolbar>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvConnections"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/spacing_5xl"
                android:paddingTop="@dimen/spacing_3xl"
                android:paddingBottom="@dimen/low_power_chip_scroll_clearance" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <include
                    layout="@layout/view_donate_pill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_5xl"
                    android:visibility="gone" />

                <include layout="@layout/overlay_low_power_chip" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Low-power overlays (countdown banner + dim screen). Included last so
         the dim FrameLayout sits on top, identical to activity_main.xml. -->
    <include layout="@layout/overlay_low_power" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
