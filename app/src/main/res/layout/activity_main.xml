<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SATELLITE"
            android:textColor="@color/colorPrimary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorSurface"
            app:strokeColor="@color/colorCardStroke"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- ── Controller status (always visible) ─────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:id="@+id/dotController"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CONTROLLER"
                        android:textColor="@color/colorMuted"
                        android:textSize="12sp"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/tvControllerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NONE"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="13sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorOutline"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <!-- ── SCANNING ────────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/llScanning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <ProgressBar
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:indeterminateTint="@color/colorPrimary" />
                    <TextView
                        android:id="@+id/tvScanningLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scanning for servers on LAN…"
                        android:textColor="@color/colorMuted"
                        android:textSize="13sp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- ── SERVER LIST ─────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/llServerList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERVERS"
                        android:textColor="@color/colorPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="10dp" />
                    <LinearLayout
                        android:id="@+id/llServers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <TextView
                        android:id="@+id/tvNoServers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No servers found on the local network"
                        android:textColor="@color/colorMuted"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRescan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RESCAN"
                        android:layout_marginTop="12dp"
                        app:backgroundTint="@color/colorOutline"
                        android:textColor="@color/colorOnSurface" />
                </LinearLayout>

                <!-- ── PAIRING ────────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/llPairing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAIR DEVICE"
                        android:textColor="@color/colorPrimary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/tvPairingServer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorOnSurface"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enter the PIN shown in the server web UI:"
                        android:textColor="@color/colorMuted"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="PIN"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/colorPrimary"
                        app:hintTextColor="@color/colorMuted">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="8"
                            android:textColor="@color/colorPrimary"
                            android:fontFamily="monospace"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:letterSpacing="0.2" />
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView
                        android:id="@+id/tvPairError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorError"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:minHeight="18dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CANCEL"
                            android:layout_marginEnd="8dp"
                            app:backgroundTint="@color/colorOutline"
                            android:textColor="@color/colorOnSurface" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnPair"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PAIR"
                            app:backgroundTint="@color/colorPrimary"
                            android:textColor="@color/colorOnPrimary" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── CONNECTED ───────────────────────────────────────── -->
                <LinearLayout
                    android:id="@+id/llConnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONNECTED"
                        android:textColor="@color/colorSuccess"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"
                        android:layout_marginBottom="12dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="SERVER"
                            android:textColor="@color/colorMuted" android:textSize="12sp"
                            android:letterSpacing="0.04" />
                        <TextView
                            android:id="@+id/tvConnectedServer"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/colorOnSurface" android:textSize="13sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="ADDRESS"
                            android:textColor="@color/colorMuted" android:textSize="12sp"
                            android:letterSpacing="0.04" />
                        <TextView
                            android:id="@+id/tvConnectedIp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/colorOnSurface" android:textSize="13sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <!-- ── Active lock indicators ──────────────────────── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="SCREEN"
                            android:textColor="@color/colorMuted" android:textSize="12sp"
                            android:letterSpacing="0.04" />
                        <TextView
                            android:id="@+id/tvScreenLock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textColor="@color/colorMuted" android:textSize="13sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="WAKE LOCK"
                            android:textColor="@color/colorMuted" android:textSize="12sp"
                            android:letterSpacing="0.04" />
                        <TextView
                            android:id="@+id/tvWakeLock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="OFF"
                            android:textColor="@color/colorMuted" android:textSize="13sp"
                            android:fontFamily="monospace" />
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDisconnect"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DISCONNECT"
                        app:backgroundTint="@color/colorPrimaryDark"
                        android:textColor="@color/colorOnSurface" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CLIENT TELEMETRY ──────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/colorSurface"
            app:strokeColor="@color/colorCardStroke"
            app:strokeWidth="1dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CLIENT TELEMETRY"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="12dp" />

                <!-- Pipeline stats -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PIPELINE"
                    android:textColor="@color/colorMuted"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- Events/s row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="EVENTS / S" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelEventRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Samples/s row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="SAMPLES / S" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelSampleRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Hist/event row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="HIST / EVENT" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelHistAvg"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Sends/s row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="SENDS / S" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelSendRate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Total sent row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="5dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="TOTAL SENT" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelTotalSent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <!-- Last event row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="LAST EVENT" android:textColor="@color/colorMuted" android:textSize="12sp" android:letterSpacing="0.04"/>
                    <TextView android:id="@+id/tvTelLastEvent"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/colorOutline" android:layout_marginBottom="12dp"/>

                <!-- Controller state -->
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONTROLLER STATE"
                    android:textColor="@color/colorMuted" android:textSize="11sp"
                    android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

                <!-- LX / LY -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="5dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="LX" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelLX" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="     0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="LY" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelLY" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="     0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- RX / RY -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="5dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="RX" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelRX" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="     0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="RY" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelRY" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="     0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- LT / RT -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="5dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="LT" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelLT" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                            android:text="RT" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                        <TextView android:id="@+id/tvTelRT" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="  0" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- BTNS -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="wrap_content"
                        android:text="BTN" android:textColor="@color/colorMuted" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvTelBtns" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0x0000" android:textColor="@color/colorOnSurface" android:textSize="13sp" android:fontFamily="monospace"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>

