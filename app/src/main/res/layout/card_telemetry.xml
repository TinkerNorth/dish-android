<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardTelemetry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/spacing_3xl"
    android:visibility="gone"
    app:cardBackgroundColor="@color/colorSurface"
    app:strokeColor="@color/colorCardStroke"
    app:strokeWidth="@dimen/border_thin"
    app:cardElevation="0dp"
    app:cardCornerRadius="@dimen/corner_picker_row">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/telemetry_title" android:textColor="@color/colorMuted" android:textSize="@dimen/text_caption"
            android:letterSpacing="0.1" android:layout_marginBottom="@dimen/spacing_md" />

        <!-- Rates row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_xs">
            <TextView android:id="@+id/tvTelEventRate" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_evt_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelSampleRate" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_smp_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelSendRate" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_snd_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
        </LinearLayout>
        <TextView android:id="@+id/tvTelTotalSent" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/telemetry_total_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" android:layout_marginBottom="@dimen/spacing_sm" />

        <!-- Axes row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="@dimen/size_2">
            <TextView android:id="@+id/tvTelLX" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_lx_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelLY" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_ly_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelRX" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_rx_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelRY" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_ry_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvTelLT" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_lt_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelRT" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/telemetry_rt_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
            <TextView android:id="@+id/tvTelBtns" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="2" android:text="@string/telemetry_btn_placeholder" android:textColor="@color/colorMuted" android:textSize="@dimen/text_label" android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
