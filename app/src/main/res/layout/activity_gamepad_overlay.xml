<?xml version="1.0" encoding="utf-8"?>
<!--
    GAMEPAD OVERLAY — full-screen landscape host for the on-screen touch
    gamepad. Mirrors the touchpad overlay's chrome (shared overlay_header
    + same content-frame padding) so the two input surfaces feel like
    siblings of the same app and match the rest-of-app toolbar shape
    (Connections, Settings).

    CoordinatorLayout root so Snackbar swipe-to-dismiss + the low-power
    dim overlay work while the gamepad overlay is foreground. The vertical
    LinearLayout inside it stacks toolbar on top, gamepad surface below;
    the surface gets padding from the screen edges per the design-system
    "no bleed-to-edge" rule.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar: left-chevron back + page title. Style
             Widget.Dish.Toolbar is the shared piece — same chevron,
             same background, same height as the Connections + Settings
             toolbars. Title is set at runtime in onCreate so a layout
             diff can't accidentally show "Gamepad" on the touchpad
             overlay or vice versa. -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/overlayToolbar"
            style="@style/Widget.Dish.Toolbar"
            android:layout_width="match_parent" />

        <!-- Content area: gamepad surface fills. paddingBottom=?actionBarSize
             mirrors the toolbar at top so the surface sits visually
             centred instead of crowding the screen edge. -->
        <FrameLayout
            android:id="@+id/overlayContentFrame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="?attr/actionBarSize">

            <com.tinkernorth.dish.ui.common.GamepadTouchView
                android:id="@+id/gamepadTouchView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="@dimen/spacing_2xl"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_2xl" />
        </FrameLayout>
    </LinearLayout>

    <!-- Low-power overlays (countdown banner + dim screen). Included last
         so the dim FrameLayout sits on top of the gamepad and consumes
         the wake-tap, identical to activity_main.xml. -->
    <include layout="@layout/overlay_low_power" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
