<?xml version="1.0" encoding="utf-8"?>
<!-- CoordinatorLayout root so Snackbar swipe-to-dismiss works while the
     gamepad overlay is foreground. The full-screen landscape posture and
     the touch-view stack are unchanged. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.tinkernorth.dish.ui.common.GamepadTouchView
        android:id="@+id/gamepadTouchView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top-center status stack: connection pill + phone-motion pill. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <include
            android:id="@+id/statusPillConnection"
            layout="@layout/status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Phone-motion (gyro/accel) indicator. Always visible so the
             three states — streaming / paused / no-gyroscope — are never
             ambiguous; the detail line below appears only for no-gyroscope.
             The pill's text is set live by refreshMotionStatus() so a
             screen reader reads the current state instead of a stale
             contentDescription. -->
        <include
            android:id="@+id/statusPillMotion"
            layout="@layout/status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm" />

        <TextView
            android:id="@+id/tvMotionDetail"
            style="@style/TextAppearance.Dish.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:maxWidth="@dimen/dialog_inline_max_width"
            android:gravity="center_horizontal"
            android:text="@string/motion_unavailable_detail"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExitGamepad"
        style="@style/Widget.Dish.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_xl"
        android:text="@string/overlay_action_back"
        android:textSize="@dimen/text_label"
        android:minWidth="@dimen/button_min_width" />

    <!-- Low-power overlays (countdown banner + dim screen). Included last so
         the dim FrameLayout sits on top of the gamepad and consumes the
         wake-tap, identical to activity_main.xml. -->
    <include layout="@layout/overlay_low_power" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
