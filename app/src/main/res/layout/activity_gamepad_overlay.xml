<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.tinkernorth.dish.ui.common.GamepadTouchView
        android:id="@+id/gamepadTouchView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_pill"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:alpha="0.85">

        <View
            android:id="@+id/dotOverlay"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Streaming"
            android:textColor="@color/colorOnSurface"
            android:textSize="11sp"
            android:fontFamily="monospace" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExitGamepad"
        style="@style/Widget.Dish.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="12dp"
        android:text="BACK"
        android:textSize="11sp"
        android:minWidth="64dp" />

    <!-- Low-power overlays (countdown banner + dim screen). Included last so
         the dim FrameLayout sits on top of the gamepad and consumes the
         wake-tap, identical to activity_main.xml. -->
    <include layout="@layout/overlay_low_power" />
</FrameLayout>
