<?xml version="1.0" encoding="utf-8"?>
<!-- Label + chip-flex row used by every chip-driven inline picker (Type,
     Touchpad mode). The adapter sets tvChipRowLabel and fills llChips with
     N @layout/chip_pickable inflations at bind time. Top margin matches the
     previous programmatic value so the three sibling rows in a card (Type,
     Motion, Touchpad) stack with consistent vertical rhythm. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/tvChipRowLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="10dp"
        android:textColor="@color/colorMuted"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <LinearLayout
        android:id="@+id/llChips"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal" />
</LinearLayout>
