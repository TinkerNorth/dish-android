<?xml version="1.0" encoding="utf-8"?>
<!-- Custom PIN dialog. Replaces the MaterialAlertDialogBuilder pattern so the
     Pair button can host an in-flight DishSpinner and the dialog doesn't
     auto-dismiss on submit (the old behaviour reset the user's PIN typing on
     every retry). Surface is bg_pill — matches every other floating banner /
     dim-overlay pill in the v6 theme — and the title/subtitle/error labels
     all follow the monospace + letter-spaced chrome convention. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_pill"
    android:paddingHorizontal="@dimen/spacing_6xl"
    android:paddingVertical="@dimen/size_22">

    <TextView
        style="@style/TextAppearance.Dish.Label.Accent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pair_dialog_eyebrow" />

    <TextView
        android:id="@+id/tvPairTitle"
        style="@style/TextAppearance.Dish.Title.Large"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/pair_dialog_title" />

    <TextView
        android:id="@+id/tvPairSubtitle"
        style="@style/TextAppearance.Dish.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/pair_dialog_subtitle" />

    <EditText
        android:id="@+id/etPin"
        style="@style/Widget.Dish.EditText.Pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_4xl"
        android:hint="@string/pair_dialog_pin_hint"
        android:inputType="numberPassword"
        android:maxLength="8"
        android:autofillHints="@null"
        android:importantForAutofill="no"
        tools:targetApi="26" />

    <!-- Inline error surface: hidden until the server rejects the PIN, then
         shown under the field with the same error red used elsewhere.
         Adopts BodySmall and overrides textColor to colorError — the
         severity colour is callsite intent, not a style-wide concern. -->
    <TextView
        android:id="@+id/tvPairError"
        style="@style/TextAppearance.Dish.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:textColor="@color/colorError"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_5xl"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairCancel"
            style="@style/Widget.Dish.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@android:string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairSubmit"
            style="@style/Widget.Dish.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_lg"
            android:text="@string/pair_dialog_submit" />
    </LinearLayout>
</LinearLayout>
