<?xml version="1.0" encoding="utf-8"?>
<!-- Custom PIN dialog. Replaces the MaterialAlertDialogBuilder pattern so the
     Pair button can host an in-flight DishSpinner and the dialog doesn't
     auto-dismiss on submit (the old behaviour reset the user's PIN typing on
     every retry). Surface is bg_pill (matches every other floating banner /
     dim-overlay pill in the v6 theme) and the title/subtitle labels all
     follow the monospace + letter-spaced chrome convention.

     PIN input is a TextInputLayout (OutlinedBox via Widget.Dish.TextInputLayout.Pin)
     wrapping a TextInputEditText. The inline error TextView that used to
     live under the field was retired during the M3 audit: TextInputLayout's
     own .setError(msg) drives the error stroke + the helper-text row + the
     a11y live-region announcement in one call, which is both spec-correct
     and announces failures to TalkBack users (the prior TextView did not). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_pill"
    android:paddingHorizontal="@dimen/spacing_6xl"
    android:paddingVertical="@dimen/size_22">

    <TextView
        style="@style/TextAppearance.Dish.Label.Accent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/pair_dialog_eyebrow" />

    <TextView
        android:id="@+id/tvPairTitle"
        style="@style/TextAppearance.Dish.Title.Large"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/pair_dialog_title" />

    <TextView
        android:id="@+id/tvPairSubtitle"
        style="@style/TextAppearance.Dish.BodySmall"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/pair_dialog_subtitle" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilPin"
        style="@style/Widget.Dish.TextInputLayout.Pin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_4xl">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPin"
            style="@style/Widget.Dish.EditText.Pin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/pair_dialog_pin_hint"
            android:inputType="numberPassword"
            android:maxLength="8"
            android:autofillHints="@null"
            android:importantForAutofill="no"
            tools:targetApi="26" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_5xl"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairCancel"
            style="@style/Widget.Dish.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@android:string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairSubmit"
            style="@style/Widget.Dish.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_lg"
            android:text="@string/pair_dialog_submit" />
    </LinearLayout>

    <!-- Path B: this dish shows its own PIN; the operator accepts it on the
         satellite. Toggled GONE by PairPinDialog when no client PIN is set. -->
    <LinearLayout
        android:id="@+id/clientPinSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_5xl"
        android:orientation="vertical">

        <TextView
            style="@style/TextAppearance.Dish.BodySmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pair_dialog_or_show_pin" />

        <TextView
            android:id="@+id/tvClientPin"
            style="@style/TextAppearance.Dish.Title.Large"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:letterSpacing="0.3"
            tools:text="4821" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPairApprove"
            style="@style/Widget.Dish.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/pair_dialog_request_approval" />
    </LinearLayout>
</LinearLayout>
