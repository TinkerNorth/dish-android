<?xml version="1.0" encoding="utf-8"?>
<!-- Single-include host for theme-styled banner notifications. Activities
     drop this into their root FrameLayout (after overlay_low_power so dim
     and notifications don't visually collide). The merge root keeps the
     activity layout tree flat.

     layout_gravity="bottom" pins the host to the bottom edge of the activity
     FrameLayout — banners and the LowPowerManager countdown pill share the
     same general region and stack via DishNotificationHost's dynamic
     bottomInsetFlow. Height is wrap_content so the host shrinks to zero when
     no banners are visible and touches pass straight through to the content
     beneath it. -->
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <com.tinkernorth.dish.ui.common.DishNotificationHost
        android:id="@+id/dishNotificationHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:elevation="8dp"
        android:clickable="false"
        android:focusable="false" />

</merge>
