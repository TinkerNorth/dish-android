<?xml version="1.0" encoding="utf-8"?>
<!--
    Settings screen, recreated from the Claude Design "Settings.html"
    handoff. Toolbar (chevron + "Settings") kept from the previous version
    per Laura's request; body is the two-section layout below.

      ── DIAGNOSTICS ──
        Toggle card: bug glyph in a tinted square container, title + body
        copy, SwitchMaterial. Below the card, a mono status dot + label
        ("Reporting enabled" / "Reporting disabled") that re-renders in
        real time as the toggle flips.

      ── ABOUT ──
        Privacy-policy link card: shield glyph, title + mono URL subtitle,
        open-in-new trailing affordance.
        Version row (separate card): mono label + value.

      Brand footer (mono micro-eyebrow) caps the bottom of the screen.

    Token mapping per colors_and_type.css → app/src/main/res/values/colors.xml:
      C.signal (#4FE3FF) → @color/colorPrimary
      C.body   (#E6ECFF) → @color/colorOnSurface
      C.muted  (#93A0C8) → @color/colorMuted
      C.night  (#0C1027) → @color/colorSurface
      C.cardStroke (rgba 0.12) → @color/colorCardStroke (#1F4FE3FF)
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBackground"
            app:title="@string/settings_title"
            app:titleTextColor="@color/colorOnSurface"
            app:navigationIcon="@drawable/ic_chevron_left" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="@dimen/spacing_5xl"
            android:paddingTop="@dimen/spacing_md"
            android:paddingBottom="@dimen/spacing_6xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ═══ DIAGNOSTICS ════════════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_diagnostics"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_label"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:paddingBottom="@dimen/spacing_lg" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="@dimen/corner_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorCardStroke"
                    app:strokeWidth="@dimen/border_thin">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:padding="@dimen/card_padding">

                        <FrameLayout
                            android:layout_width="@dimen/icon_card_container"
                            android:layout_height="@dimen/icon_card_container"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:layout_width="@dimen/icon_card_glyph"
                                android:layout_height="@dimen/icon_card_glyph"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_bug"
                                app:tint="@color/colorPrimary"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_2xl"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_crash_reporting_title"
                                android:textColor="@color/colorOnSurface"
                                android:textSize="@dimen/text_title_sm"
                                android:textStyle="normal"
                                android:fontFamily="sans-serif-medium"
                                android:lineSpacingMultiplier="1.3" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_crash_reporting_body"
                                android:textColor="@color/colorMuted"
                                android:textSize="@dimen/text_body"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:lineSpacingMultiplier="1.35" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchCrashReporting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_xl"
                            android:layout_marginTop="@dimen/size_2"
                            android:contentDescription="@string/settings_crash_reporting_title"
                            android:textOn=""
                            android:textOff=""
                            app:showText="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══ ABOUT ══════════════════════════════════════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_section_about"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_label"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.14"
                    android:layout_marginTop="@dimen/size_22"
                    android:paddingBottom="@dimen/spacing_lg" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPrivacyPolicy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="@dimen/corner_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorCardStroke"
                    app:strokeWidth="@dimen/border_thin">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/card_padding">

                        <FrameLayout
                            android:layout_width="@dimen/icon_card_container"
                            android:layout_height="@dimen/icon_card_container"
                            android:background="@drawable/bg_icon_container">

                            <ImageView
                                android:layout_width="@dimen/icon_card_glyph"
                                android:layout_height="@dimen/icon_card_glyph"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_shield"
                                android:importantForAccessibility="no" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_2xl"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/menu_privacy_policy"
                                android:textColor="@color/colorOnSurface"
                                android:textSize="@dimen/text_title_sm"
                                android:fontFamily="sans-serif-medium"
                                android:lineSpacingMultiplier="1.3" />

                            <TextView
                                android:id="@+id/tvPrivacyPolicySubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/colorMuted"
                                android:textSize="@dimen/text_body"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.02"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:layout_marginTop="@dimen/spacing_xs" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="@dimen/icon_card_glyph"
                            android:layout_height="@dimen/icon_card_glyph"
                            android:layout_marginStart="@dimen/spacing_xl"
                            android:src="@drawable/ic_open_in_new"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Version row. Wrapped in its own card so future "About" rows
                     (license, attributions) can stack inside the same card with
                     hairline dividers, matching the design's MetaRow pattern. -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_margin_bottom"
                    app:cardBackgroundColor="@color/colorSurface"
                    app:cardCornerRadius="@dimen/corner_card"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/colorCardStroke"
                    app:strokeWidth="@dimen/border_thin">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/card_padding_horizontal"
                        android:paddingVertical="@dimen/size_11">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_version_label"
                            android:textColor="@color/colorMuted"
                            android:textSize="@dimen/text_label"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.12"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvVersion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_xl"
                            android:gravity="end"
                            android:textColor="@color/colorOnSurface"
                            android:textSize="@dimen/text_body"
                            android:fontFamily="monospace"
                            android:singleLine="true"
                            android:ellipsize="end" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Brand footer — stylistic constant, not localised. -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/size_32"
                    android:text="@string/settings_brand_footer"
                    android:textColor="@color/colorMuted"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.18"
                    android:textAllCaps="true"
                    android:gravity="center"
                    android:alpha="0.7" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
