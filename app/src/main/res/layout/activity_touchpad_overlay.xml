<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen landscape overlay for the on-screen touchpad. Sibling to
     activity_gamepad_overlay.xml — same scaffolding (CoordinatorLayout root,
     status pill, exit button), different input surface. -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.tinkernorth.dish.ui.common.TouchpadSurfaceView
        android:id="@+id/touchpadSurfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top-center status pill — mirrors the gamepad overlay so the two
         overlays feel like siblings. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <include
            android:id="@+id/statusPillTouchpad"
            layout="@layout/status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExitTouchpad"
        style="@style/Widget.Dish.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/touch_target_min"
        android:layout_gravity="top|end"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_xl"
        android:text="@string/overlay_action_back"
        android:textSize="@dimen/text_label"
        android:minWidth="@dimen/button_min_width" />

    <!-- Low-power overlays (countdown banner + dim screen). Same include
         the gamepad overlay uses; the dim FrameLayout sits on top of the
         touchpad and consumes the wake-tap. -->
    <include layout="@layout/overlay_low_power" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
