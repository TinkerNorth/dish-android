<?xml version="1.0" encoding="utf-8"?>
<!-- ENTERING activity fades up from 0% alpha over motion_duration_medium with
     the dish_ease_emphasized curve (M3's top-level navigation signature).
     Paired with fade_through_exit on the leaving activity, this produces an
     "into space" cross-fade between screens against the deep-navy palette:
     more deliberate than the prior standard-curve fade, more on-spec than
     the platform default cut. -->
<alpha xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromAlpha="0.0"
    android:toAlpha="1.0"
    android:duration="@integer/motion_duration_medium"
    android:interpolator="@interpolator/dish_ease_emphasized" />
