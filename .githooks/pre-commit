#!/bin/bash
# Dish Android pre-commit hook.
#
# Two fast checks, each gated on what's actually staged:
#   1. clang-format (autofix) on staged JNI C/C++ files.
#   2. Translation completeness when any values*/strings.xml is staged —
#      mirrors the MissingTranslation lint check that CI runs via
#      ./gradlew lint, but ~30× faster (Python, no Gradle warmup).
#
# Both tools gracefully skip if their binary is missing so devs who haven't
# yet run setup-hooks.sh or installed the tool aren't blocked locally — CI
# enforces the same checks definitively.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ── clang-format ─────────────────────────────────────────────────────────
staged_jni=$(git diff --cached --name-only --diff-filter=ACM -z \
    -- 'app/src/main/cpp/*.cpp' 'app/src/main/cpp/*.h' 'app/src/main/cpp/*.c' \
    | tr '\0' '\n' | sed '/^$/d')

if [ -n "$staged_jni" ]; then
    if command -v clang-format >/dev/null 2>&1; then
        echo "▶ clang-format (staged JNI files)"
        echo "$staged_jni" | while IFS= read -r file; do
            clang-format -i "$file"
            git add "$file"
        done
    else
        echo "⚠  clang-format not installed — skipping (install clang-format)"
    fi
fi

# ── translation completeness ─────────────────────────────────────────────
# Triggered only when a strings.xml file is touched. Matches both
# values/strings.xml (the source) and values-*/strings.xml (each locale).
staged_strings=$(git diff --cached --name-only --diff-filter=ACM \
    | grep -E '^app/src/main/res/values[^/]*/strings\.xml$' || true)

if [ -n "$staged_strings" ]; then
    if command -v python3 >/dev/null 2>&1; then
        echo "▶ check-translations (staged values*/strings.xml)"
        if ! python3 "$REPO_ROOT/scripts/check-translations.py"; then
            echo
            echo "✗ commit blocked: a string in values/strings.xml is not"
            echo "  translated in every locale. Add the missing translations,"
            echo "  mark the string translatable=\"false\", or rerun the commit"
            echo "  with --no-verify if you know what you're doing."
            exit 1
        fi
    else
        echo "⚠  python3 not installed — skipping translation check"
    fi
fi
